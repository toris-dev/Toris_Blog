---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import CardFX from '../components/CardFX.astro';
import LogoMark from '../components/LogoMark.astro';
import { COMPANY } from '../lib/site';
import { fileBaseName, formatDate, toPlainExcerpt } from '../lib/slug';
import { computeStats } from '../lib/stats';
import { projects } from '../../../src/data/projects';
import { enCat, enName, enTagline } from '../lib/en';

const live = projects.filter((p) => p.status === '운영 중');
const featured = live.slice(0, 4);
const sinceYear = Math.min(
  ...projects.map((p) => parseInt(p.year, 10)).filter((y) => !Number.isNaN(y))
);

const entries = await getCollection('posts');
const latestPosts = entries
  .map((post) => ({
    slug: post.id,
    title: post.data.title || fileBaseName(post.filePath) || post.id,
    description: post.data.description || toPlainExcerpt(post.body || '', 110),
    date: post.data.date || '',
    dateLabel: formatDate(post.data.date)
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);

// 신뢰 지표 — 단일 출처(lib/stats)에서 계산, 하드코딩 금지
const stats = computeStats(projects, entries.length);
const oss = projects.filter((p) => /npm/i.test(`${p.platform} ${p.category}`));

// 제품 월(벽) — 실제 레지스트리 전체를 3열로 분배
const wallCols: (typeof projects)[number][][] = [[], [], []];
projects.forEach((p, i) => wallCols[i % 3].push(p));

const services = [
  {
    label: 'WEB · MOBILE',
    title: 'Web · Mobile Product Development',
    problem: 'You have the idea and requirements, but no team to finish it.',
    outcome: 'Products that actually ship to stores and browsers',
    scope: 'Planning · Design · Build · Deploy · Operate',
    href: '/contact',
    linkLabel: 'Start a conversation',
    demo: 'sync',
    wide: true
  },
  {
    label: 'MVP',
    title: 'MVP · Prototype',
    problem: 'You need to validate the idea in the market, fast.',
    outcome: 'A tangible minimum product within weeks',
    scope: 'Core flow · Landing · Validation metrics',
    href: '/process',
    linkLabel: 'See how we work',
    demo: 'mvp',
    wide: false
  },
  {
    label: 'AUTOMATION',
    title: 'AI · Workflow Automation',
    problem: 'Repetitive work keeps draining human hours.',
    outcome: 'Pipelines that collect → summarize → publish',
    scope: 'LLM workflows · Bots · Back office',
    href: '/contact',
    linkLabel: 'Talk automation',
    demo: 'pipe',
    wide: false
  },
  {
    label: 'DESKTOP',
    title: 'Desktop Applications',
    problem: 'You need local file & system access the web cannot give.',
    outcome: 'Native apps installed on macOS & Windows',
    scope: 'Tauri · Rust · Auto-update · Release delivery',
    href: '/contact',
    linkLabel: 'Talk desktop apps',
    demo: 'win',
    wide: true
  }
] as const;

const steps = [
  { n: '01', t: 'Inquiry · Consultation', d: 'We listen to what you want to build and your constraints.', out: 'First reply within 24h · NDA on request' },
  { n: '02', t: 'Scoping', d: 'Scope, timeline, and cost — fixed in writing.', out: 'Scope doc · Schedule · Quote' },
  { n: '03', t: 'Design · Prototype', d: 'We validate direction with a draft you can touch.', out: 'A working prototype' },
  { n: '04', t: 'Build · Verify', d: 'Working results shared every week.', out: 'Weekly demos · Staging · Changelog' },
  { n: '05', t: 'Launch · Operate', d: 'Improvement continues with metrics after deploy.', out: 'Deploy · Monitoring · Iteration' }
] as const;

// 밸류 서클 — 거북이 방식의 세 축
const values = [
  { en: 'STEADY', ko: 'No rush, no stopping', d: "Slow like a turtle — but never standing still" },
  { en: 'COMPLETE', ko: 'What we start, we ship', d: 'Every product we begin reaches launch' },
  { en: 'OPERATE', ko: 'Beyond the launch', d: 'We own the improvements after deploy' }
] as const;

// 서비스 링크(웹사이트·스토어·릴리스 다운로드)만 클릭 허용.
const isServiceLink = (url: string) =>
  !url.startsWith('https://github.com/') || /\/releases\/?$/.test(url);
---

<Base
  title="Toris — Ideas into Shippable Products | Product Engineering Studio, Seoul"
  description="Toris is a one-person software studio in Seoul run by a founder-engineer. We build and operate our own products — MemeCatch (catchmeme.com), bubbleBible — and take client ideas from planning to launch."
  path="/en"
>
  <!-- ====================== S1. Hero — 글로우 인트로 ====================== -->
  <section id="hero" class="relative overflow-hidden">
    <canvas
      id="shell-canvas"
      class="pointer-events-none absolute inset-0 h-full w-full"
      aria-hidden="true"></canvas>
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <span class="hero-blob hb-1"></span>
      <span class="hero-blob hb-2"></span>
      <span class="hero-blob hb-3"></span>
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-paper to-transparent"
      aria-hidden="true"
    >
    </div>

    <div class="relative mx-auto flex min-h-[100dvh] max-w-5xl flex-col items-center justify-center px-5 py-28 text-center">
      <div class="hero-in hero-glow relative">
        <LogoMark class="size-20 sm:size-24" />
      </div>
      <p class="hero-in mt-8 font-mono text-[11px] font-medium tracking-[0.3em] text-mint-deep" style="transition-delay: 120ms">
        TORIS — PRODUCT ENGINEERING STUDIO · SEOUL
      </p>
      <h1
        class="hero-in font-display mt-6 break-keep text-[clamp(2.6rem,7.5vw,5.75rem)] leading-[1.12] text-ink"
        style="transition-delay: 240ms"
      >
        Ideas into<br />
        <span class="text-mint-deep">shippable products</span>.
      </h1>
      <p
        class="hero-in mx-auto mt-7 max-w-xl break-keep text-base leading-relaxed text-ink-dim sm:text-lg"
        style="transition-delay: 360ms"
      >
        Toris is a software studio that takes web, mobile, and AI automation
        products from planning to launch and operation.
      </p>

      <div class="hero-in mt-11 flex flex-wrap items-center justify-center gap-4" style="transition-delay: 480ms">
        <a
          href="/contact"
          class="btn-magnet btn-shine relative inline-flex h-13 items-center gap-3 overflow-hidden rounded-xl bg-ink px-8 py-3.5 text-[15px] font-semibold text-paper transition-colors duration-300 hover:bg-mint focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-mint"
        >
          Start a conversation
          <svg viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
            <path d="M5 12h14m-6-6 6 6-6 6"></path>
          </svg>
        </a>
        <a
          href="/projects"
          class="inline-flex h-13 items-center gap-2 rounded-xl border border-line bg-card/60 px-7 py-3.5 text-[15px] font-medium text-ink-dim transition-all duration-300 hover:border-mint hover:text-ink focus-visible:outline-2 focus-visible:outline-mint"
        >
          Explore our products
        </a>
      </div>

      <!-- 배포 흐름 라인 -->
      <div class="hero-in mt-16 w-full max-w-md" style="transition-delay: 600ms" aria-hidden="true">
        <div class="pipe relative h-px bg-line">
          <span class="pipe-dot"></span>
        </div>
        <div class="mt-2 flex justify-between font-mono text-[10px] tracking-[0.18em] text-muted">
          <span>COMMIT</span><span>BUILD</span><span>DEPLOY</span><span>OPERATE</span>
        </div>
      </div>

      <p class="hero-in mt-6" style="transition-delay: 560ms">
        <a href="/?lang=ko" class="font-mono text-xs text-muted underline underline-offset-4 transition-colors hover:text-mint-deep focus-visible:outline-2 focus-visible:outline-mint">한국어로 보기</a>
      </p>

      <!-- 스크롤 큐 -->
      <div class="hero-in absolute bottom-8 left-1/2 -translate-x-1/2" style="transition-delay: 720ms" aria-hidden="true">
        <span class="scroll-cue block h-9 w-5 rounded-full border border-line">
          <i class="mx-auto mt-1.5 block h-2 w-0.5 rounded bg-mint"></i>
        </span>
      </div>
    </div>

    <!-- 플로팅 제품 패널 — 실제 운영 데이터만 표기 -->
    <div class="pointer-events-none absolute inset-0 hidden xl:block" aria-hidden="true">
      <div class="float-panel glass absolute right-[6%] top-[22%] w-64 rounded-2xl p-4" data-depth="16">
        <p class="font-mono text-[10px] tracking-[0.2em] text-muted">DEPLOYMENTS</p>
        <ul class="mt-3 space-y-2.5">
          <li class="flex items-center justify-between text-[13px]">
            <span class="font-medium text-ink">catchmeme.com</span>
            <span class="flex items-center gap-1.5 text-live"><span class="size-1.5 rounded-full bg-live"></span>Live</span>
          </li>
          <li class="flex items-center justify-between text-[13px]">
            <span class="font-medium text-ink">toris.kr</span>
            <span class="flex items-center gap-1.5 text-live"><span class="size-1.5 rounded-full bg-live"></span>Live</span>
          </li>
          <li class="flex items-center justify-between text-[13px]">
            <span class="font-medium text-ink">asyncraft</span>
            <span class="font-mono text-[11px] text-muted">npm</span>
          </li>
        </ul>
      </div>
      <div class="float-panel glass absolute left-[5%] top-[58%] w-72 rounded-2xl p-4 font-mono text-[12px] leading-6" data-depth="26">
        <p class="text-muted">$ pnpm run deploy</p>
        <p class="text-ink-dim">✓ 30 pages built</p>
        <p class="text-mint-deep">▲ deployed to production</p>
      </div>
    </div>
  </section>

  <!-- ==================== 운영 제품 마퀴(실데이터) ==================== -->
  <div class="marquee overflow-hidden border-y border-line bg-paper-2/70 py-3.5" aria-hidden="true">
    <div class="marquee-track flex w-max">
      {
        [0, 1].map(() => (
          <div class="marquee-seg flex shrink-0 items-center">
            {live.map((p) => (
              <span class="mx-7 inline-flex items-center gap-2.5 font-mono text-[12px] tracking-[0.22em] text-muted">
                <i class="size-1 rounded-full bg-mint" />
                {enName(p).toUpperCase()}
              </span>
            ))}
          </div>
        ))
      }
    </div>
  </div>

  <!-- =================== S2. 스테이트먼트 — 브랜드 선언 =================== -->
  <section class="relative flex min-h-[72vh] items-center overflow-hidden">
    <div class="aurora pointer-events-none absolute inset-0 opacity-70" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-6xl px-5 py-28 text-center">
      <p class="reveal font-mono text-[11px] tracking-[0.3em] text-muted">OUR PROMISE</p>
      <p class="reveal font-display mt-8 break-keep text-[clamp(2.4rem,7vw,5.5rem)] leading-[1.18]">
        <span class="text-ink-dim">We never rush —</span><br />
        <span class="text-mint-deep">and we always ship</span>
      </p>
      <p class="reveal mx-auto mt-8 max-w-lg break-keep text-[15px] leading-relaxed text-muted">
        At a turtle's pace — quietly, but never stopping. Deliverables over
        contracts, deployments over words.
      </p>
    </div>
  </section>

  <!-- ================ S3. 제품 월 — 여정과 지표(실데이터) ================ -->
  <section class="relative overflow-hidden border-y border-line bg-paper-2/40">
    <!-- 배경: 프로젝트 타일 3열 수직 흐름 -->
    <div class="wall pointer-events-none absolute inset-0 grid grid-cols-2 gap-4 px-4 opacity-[0.5] md:grid-cols-3" aria-hidden="true">
      {
        wallCols.map((col, ci) => (
          <div class:list={['wall-col flex flex-col gap-4', ci === 2 && 'hidden md:flex']} style={`animation-duration: ${44 + ci * 10}s; animation-direction: ${ci % 2 ? 'reverse' : 'normal'}`}>
            {[0, 1].map(() => (
              <div class="flex shrink-0 flex-col gap-4">
                {col.map((p) => (
                  <div class="rounded-2xl border border-line bg-card p-5">
                    <p class="font-mono text-[9px] tracking-[0.18em] text-muted uppercase">{enCat(p)}</p>
                    <p class="mt-1.5 truncate text-sm font-semibold text-ink-dim">{enName(p)}</p>
                  </div>
                ))}
              </div>
            ))}
          </div>
        ))
      }
    </div>
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-paper via-transparent to-paper" aria-hidden="true"></div>

    <!-- 전경: 클레임 + 지표 -->
    <div class="relative mx-auto max-w-6xl px-5 py-40 text-center sm:py-48">
      <p class="reveal font-mono text-[11px] tracking-[0.3em] text-mint-deep">SINCE {sinceYear} — KEEP SHIPPING</p>
      <h2 class="reveal font-display mx-auto mt-6 max-w-3xl break-keep text-[clamp(1.9rem,5vw,3.4rem)] leading-[1.25] text-ink">
        From MemeCatch to TraceDesk —<br />built and operated by ourselves
      </h2>
      <dl class="reveal mx-auto mt-14 flex max-w-2xl flex-wrap items-end justify-center gap-x-16 gap-y-8">
        <div>
          <dd class="font-display text-6xl text-ink sm:text-7xl"><span data-count={String(stats.total)}>{stats.total}</span><span class="text-mint-deep">+</span></dd>
          <dt class="mt-2 font-mono text-[11px] tracking-[0.2em] text-muted">PROJECTS</dt>
        </div>
        <div>
          <dd class="font-display text-6xl text-ink sm:text-7xl"><span data-count={String(stats.live)}>{stats.live}</span></dd>
          <dt class="mt-2 font-mono text-[11px] tracking-[0.2em] text-muted">LIVE NOW</dt>
        </div>
        <div>
          <dd class="font-display text-6xl text-ink sm:text-7xl"><span data-count={String(stats.posts)}>{stats.posts}</span></dd>
          <dt class="mt-2 font-mono text-[11px] tracking-[0.2em] text-muted">TECH LOGS</dt>
        </div>
      </dl>
    </div>
  </section>

  <!-- ================== S4. 밸류 서클 — 거북이의 방식 ================== -->
  <section class="relative overflow-hidden">
    <div class="mx-auto max-w-6xl px-5 py-28 sm:py-36">
      <p class="reveal text-center font-mono text-[11px] tracking-[0.3em] text-muted">HOW WE MOVE</p>
      <div class="mt-14 grid gap-4 sm:grid-cols-3">
        {
          values.map((v, i) => (
            <div
              class="card-3d reveal group relative overflow-hidden rounded-2xl border border-line bg-card p-8 transition-[border-color] duration-300 hover:border-mint/70"
              style={`transition-delay: ${i * 100}ms`}
            >
              <span class="card-glare" aria-hidden="true" />
              <p class="font-mono text-[10px] tracking-[0.28em] text-muted">0{i + 1}</p>
              <p class="mt-4 font-mono text-xl tracking-[0.18em] text-mint-deep">{v.en}</p>
              <p class="font-display mt-2 text-lg text-ink">{v.ko}</p>
              <p class="mt-3 break-keep text-sm leading-relaxed text-ink-dim">{v.d}</p>
              <span class="absolute -bottom-px left-0 h-px w-0 bg-mint transition-all duration-500 group-hover:w-full" aria-hidden="true" />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ========================= S5. Services ========================= -->
  <section class="border-t border-line bg-paper-2/40">
    <div class="mx-auto max-w-6xl px-5 py-24 sm:py-28">
      <div class="reveal grid gap-6 md:grid-cols-[1fr_2fr]">
        <div>
          <p class="font-mono text-[11px] font-medium tracking-[0.28em] text-mint-deep">SERVICES</p>
          <h2 class="font-display mt-4 text-3xl leading-snug text-ink sm:text-4xl">
            Start small,<br />finish everything
          </h2>
        </div>
        <p class="self-end break-keep text-[15px] leading-relaxed text-ink-dim md:max-w-md md:justify-self-end">
          Not an agency relationship — a partner who builds the product with you.
        </p>
      </div>

      <div class="mt-12 grid gap-4 md:grid-cols-3">
        {
          services.map((s, i) => (
            <article
              class:list={[
                'svc-card reveal group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-card p-7 transition-all duration-300 hover:-translate-y-1 hover:border-mint/70 hover:shadow-[0_20px_48px_-24px_color-mix(in_srgb,var(--color-mint)_28%,transparent)] sm:p-8',
                s.wide && 'md:col-span-2'
              ]}
              style={`transition-delay: ${i * 90}ms`}
            >
              <span class="font-mono text-[10px] font-medium tracking-[0.24em] text-mint-deep">{s.label}</span>
              <h3 class="font-display mt-4 text-2xl text-ink">{s.title}</h3>

              {s.demo === 'sync' && (
                <div class="demo-sync mt-6 flex items-center gap-3" aria-hidden="true">
                  <div class="w-40 rounded-lg border border-line bg-paper p-2">
                    <div class="flex gap-1"><i class="size-1.5 rounded-full bg-line" /><i class="size-1.5 rounded-full bg-line" /><i class="size-1.5 rounded-full bg-line" /></div>
                    <div class="mt-2 space-y-1.5">
                      <div class="demo-bar h-1.5 w-4/5 rounded bg-mint/40" />
                      <div class="demo-bar h-1.5 w-3/5 rounded bg-line" style="transition-delay:80ms" />
                      <div class="demo-bar h-1.5 w-2/3 rounded bg-line" style="transition-delay:160ms" />
                    </div>
                  </div>
                  <div class="demo-link h-px flex-1 bg-line" />
                  <div class="w-14 rounded-lg border border-line bg-paper p-1.5">
                    <div class="mx-auto h-16 w-full rounded border border-line bg-card p-1">
                      <div class="demo-bar h-1 w-full rounded bg-mint/40" />
                      <div class="demo-bar mt-1 h-1 w-2/3 rounded bg-line" style="transition-delay:120ms" />
                    </div>
                  </div>
                </div>
              )}
              {s.demo === 'mvp' && (
                <div class="demo-mvp mt-6 grid grid-cols-3 gap-2" aria-hidden="true">
                  <div class="demo-block h-14 rounded-lg border border-dashed border-line" />
                  <div class="demo-block h-14 rounded-lg border border-dashed border-line" style="transition-delay:100ms" />
                  <div class="demo-block h-14 rounded-lg border border-dashed border-line" style="transition-delay:200ms" />
                </div>
              )}
              {s.demo === 'pipe' && (
                <div class="demo-pipe mt-6" aria-hidden="true">
                  <div class="relative flex items-center justify-between">
                    <span class="pipe-node">Collect</span>
                    <span class="pipe-node">Summarize</span>
                    <span class="pipe-node">Publish</span>
                    <i class="absolute inset-x-8 top-1/2 -z-10 h-px bg-line" />
                    <i class="pipe-runner" />
                  </div>
                </div>
              )}
              {s.demo === 'win' && (
                <div class="demo-win mt-6 flex items-end gap-3" aria-hidden="true">
                  <div class="w-44 rounded-lg border border-line bg-paper">
                    <div class="flex items-center gap-1 border-b border-line px-2 py-1.5">
                      <i class="size-1.5 rounded-full bg-coral/70" /><i class="size-1.5 rounded-full bg-line" /><i class="size-1.5 rounded-full bg-mint/70" />
                      <span class="ml-1.5 font-mono text-[8px] tracking-wider text-muted">TRACEDESK</span>
                    </div>
                    <div class="space-y-1.5 p-2">
                      <div class="demo-bar h-1.5 w-3/4 rounded bg-mint/40" />
                      <div class="demo-bar h-1.5 w-1/2 rounded bg-line" style="transition-delay:80ms" />
                      <div class="demo-bar h-1.5 w-2/3 rounded bg-line" style="transition-delay:160ms" />
                    </div>
                  </div>
                  <p class="flex items-center gap-1.5 pb-1 font-mono text-[10px] text-muted">
                    <i class="size-1 rounded-full bg-live" />
                    auto-update ready
                  </p>
                </div>
              )}

              <dl class="mt-6 space-y-2.5 text-sm">
                <div class="flex gap-3">
                  <dt class="w-12 shrink-0 font-mono text-[10px] leading-6 tracking-[0.16em] text-muted">Problem</dt>
                  <dd class="break-keep text-ink-dim">{s.problem}</dd>
                </div>
                <div class="flex gap-3">
                  <dt class="w-12 shrink-0 font-mono text-[10px] leading-6 tracking-[0.16em] text-muted">Outcome</dt>
                  <dd class="break-keep font-medium text-ink">{s.outcome}</dd>
                </div>
                <div class="flex gap-3">
                  <dt class="w-12 shrink-0 font-mono text-[10px] leading-6 tracking-[0.16em] text-muted">Scope</dt>
                  <dd class="text-ink-dim">{s.scope}</dd>
                </div>
              </dl>

              <a
                href={s.href}
                class="mt-auto inline-flex items-center gap-1.5 pt-6 text-sm font-semibold text-mint-deep transition-colors hover:text-mint-deep focus-visible:outline-2 focus-visible:outline-mint"
              >
                {s.linkLabel}
                <svg viewBox="0 0 24 24" class="size-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                  <path d="M5 12h14m-6-6 6 6-6 6"></path>
                </svg>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- =========================== S6. Work =========================== -->
  <section class="mx-auto max-w-6xl px-5 py-24 sm:py-28">
    <div class="reveal flex flex-wrap items-end justify-between gap-6">
      <div>
        <p class="font-mono text-[11px] font-medium tracking-[0.28em] text-mint-deep">WORK</p>
        <h2 class="font-display mt-4 text-3xl leading-snug text-ink sm:text-4xl">
          Products we build & operate
        </h2>
      </div>
      <a
        href="/projects"
        class="border-b border-transparent pb-1 text-sm font-medium text-ink-dim transition-colors hover:border-mint hover:text-ink focus-visible:outline-2 focus-visible:outline-mint"
      >
        View all →
      </a>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2">
      {
        featured.map((p, i) => { const linked = isServiceLink(p.github); const Tag = linked ? 'a' : 'div'; return (
          <Tag
            href={linked ? p.github : undefined}
            target={linked ? '_blank' : undefined}
            rel={linked ? 'noopener noreferrer' : undefined}
            class="card-3d reveal group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-card transition-[border-color,box-shadow] duration-300 hover:border-mint/70 hover:shadow-[0_20px_48px_-24px_color-mix(in_srgb,var(--color-mint)_28%,transparent)] focus-visible:outline-2 focus-visible:outline-mint"
