<script>
  requestAnimationFrame(() => document.body.classList.add('hero-ready'));

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ---------- 숫자 카운트업(뷰포트 진입 시 1회) ----------
  document.querySelectorAll<HTMLElement>('[data-count]').forEach((el) => {
    const target = Number(el.dataset.count || '0');
    if (reduce) {
      el.textContent = String(target);
      return;
    }
    const io = new IntersectionObserver((es) => {
      if (!es[0]?.isIntersecting) return;
      io.disconnect();
      el.textContent = '0';
      const t0 = performance.now();
      const dur = 1200;
      const tick = (now: number) => {
        const p = Math.min(1, (now - t0) / dur);
        el.textContent = String(Math.round(target * (1 - Math.pow(1 - p, 3))));
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    });
    io.observe(el);
  });

  // ---------- 히어로 육각 등껍질 캔버스(토큰 런타임 참조) ----------
  const canvas = document.getElementById('shell-canvas') as HTMLCanvasElement | null;
  const section = canvas?.parentElement;
  const ctx = canvas?.getContext('2d');
  if (canvas && ctx && section) {
    const styles = getComputedStyle(document.documentElement);
    const hex2rgb = (h: string) => {
      const m = h.trim().replace('#', '');
      return [0, 2, 4].map((i) => parseInt(m.slice(i, i + 2), 16));
    };
    const MINT = hex2rgb(styles.getPropertyValue('--color-mint') || '#10c98f');
    const CYAN = hex2rgb(styles.getPropertyValue('--color-cyan') || '#26aed4');
    let W = 0, H = 0, dpr = 1, raf = 0, running = false;
    type Cell = { x: number; y: number; heat: number; phase: number };
    let cells: Cell[] = [];
    const mouse = { x: -9999, y: -9999 };
    const R = 44;

    const build = () => {
      const rect = section.getBoundingClientRect();
      W = rect.width;
      H = rect.height;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.round(W * dpr);
      canvas.height = Math.round(H * dpr);
      cells = [];
      const dx = R * 1.732;
      const dy = R * 1.5;
      for (let row = 0; row * dy < H + R; row++) {
        for (let col = 0; col * dx < W + R; col++) {
          cells.push({
            x: col * dx + (row % 2 ? dx / 2 : 0),
            y: row * dy,
            heat: 0,
            phase: Math.random() * Math.PI * 2
          });
        }
      }
    };

    const hex = (x: number, y: number, r: number) => {
      ctx.beginPath();
      for (let i = 0; i < 6; i++) {
        const a = (Math.PI / 3) * i + Math.PI / 6;
        const px = x + r * Math.cos(a);
        const py = y + r * Math.sin(a);
        i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
      }
      ctx.closePath();
    };

    const draw = (t: number) => {
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.clearRect(0, 0, W, H);
      for (const c of cells) {
        const d = Math.hypot(c.x - mouse.x, c.y - mouse.y);
        const target = Math.max(0, 1 - d / 230);
        c.heat += (target - c.heat) * 0.08;
        const idle = 0.04 + 0.025 * Math.sin(t / 2200 + c.phase);
        const a = Math.min(0.45, idle + c.heat * 0.4);
        const [r, g, b] = c.heat > 0.5 ? CYAN : MINT;
        ctx.strokeStyle = `rgba(${r},${g},${b},${a})`;
        ctx.lineWidth = 0.8;
        hex(c.x, c.y, R - 5 + c.heat * 3);
        ctx.stroke();
      }
    };

    const frame = (t: number) => {
      if (!running) return;
      draw(t);
      raf = requestAnimationFrame(frame);
    };
    const start = () => {
      if (running || reduce) return;
      running = true;
      raf = requestAnimationFrame(frame);
    };
    const stop = () => {
      running = false;
      cancelAnimationFrame(raf);
    };

    build();
    if (reduce) draw(0);
    const ro = new ResizeObserver(() => {
      build();
      if (reduce) draw(0);
    });
    ro.observe(section);
    const io = new IntersectionObserver((es) => (es[0]?.isIntersecting ? start() : stop()));
    io.observe(section);
    section.addEventListener('pointermove', (e) => {
      const rect = section.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    });
    section.addEventListener('pointerleave', () => {
      mouse.x = -9999;
      mouse.y = -9999;
    });
  }

  // ---------- 히어로 플로팅 패널 포인터 시차 ----------
  const hero = document.getElementById('hero');
  const panels = document.querySelectorAll<HTMLElement>('.float-panel');
  if (hero && panels.length && !reduce && window.matchMedia('(pointer: fine)').matches) {
    panels.forEach((p) => p.style.setProperty('--depth', p.dataset.depth || '12'));
    let raf2 = 0;
    hero.addEventListener('pointermove', (e) => {
      const r = hero.getBoundingClientRect();
      const hx = ((e.clientX - r.left) / r.width - 0.5) * 2;
      const hy = ((e.clientY - r.top) / r.height - 0.5) * 2;
      cancelAnimationFrame(raf2);
      raf2 = requestAnimationFrame(() => {
        panels.forEach((p) => {
          p.style.setProperty('--hx', hx.toFixed(3));
          p.style.setProperty('--hy', hy.toFixed(3));
        });
      });
    });
    hero.addEventListener('pointerleave', () => {
      panels.forEach((p) => {
        p.style.setProperty('--hx', '0');
        p.style.setProperty('--hy', '0');
      });
    });
  }

  // ---------- CTA 마그네틱(±5px, pointer:fine 전용) ----------
  if (!reduce && window.matchMedia('(pointer: fine)').matches) {
    document.querySelectorAll<HTMLElement>('.btn-magnet').forEach((btn) => {
      btn.addEventListener('pointermove', (e) => {
        const r = btn.getBoundingClientRect();
        const mx = ((e.clientX - r.left) / r.width - 0.5) * 10;
        const my = ((e.clientY - r.top) / r.height - 0.5) * 8;
        btn.style.transform = `translate(${mx.toFixed(1)}px, ${my.toFixed(1)}px)`;
      });
      btn.addEventListener('pointerleave', () => {
        btn.style.transform = '';
      });
    });
  }

  // ---------- 서비스 데모 자동재생(뷰포트 진입 시) ----------
  const svcIO = new IntersectionObserver(
    (es) => es.forEach((e) => e.target.classList.toggle('demo-live', e.isIntersecting)),
    { threshold: 0.5 }
  );
  document.querySelectorAll('.svc-card').forEach((c) => svcIO.observe(c));

  // ---------- 프로세스 진행선 + 현재 단계 ----------
  const list = document.getElementById('process-list');
  const fill = document.getElementById('process-fill');
  const nowN = document.getElementById('process-now-n');
  const nowT = document.getElementById('process-now-t');
  const stepEls = document.querySelectorAll<HTMLElement>('.process-step');
  if (list && fill && stepEls.length) {
    const stepIO = new IntersectionObserver(
      (es) => {
        es.forEach((e) => {
          if (!e.isIntersecting) return;
          stepEls.forEach((s) => s.classList.remove('is-now'));
          const el = e.target as HTMLElement;
          el.classList.add('is-now');
          if (nowN && nowT) {
            nowN.textContent = el.dataset.n || '';
            nowT.textContent = el.dataset.t || '';
          }
          const idx = Array.from(stepEls).indexOf(el);
          fill.style.height = `${((idx + 1) / stepEls.length) * 100}%`;
        });
      },
      { rootMargin: '-40% 0px -50% 0px' }
    );
    stepEls.forEach((s) => stepIO.observe(s));
    if (reduce) fill.style.transition = 'none';
  }
</script>
