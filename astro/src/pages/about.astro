---
import Base from '../layouts/Base.astro';
import CardFX from '../components/CardFX.astro';
import { COMPANY } from '../lib/site';

const values = [
  {
    title: '작게 시작한다',
    body: '큰 계획보다 만질 수 있는 MVP를 먼저 만듭니다. 작은 범위로 빠르게 검증하고, 배운 것 위에 다음 걸음을 쌓습니다.',
    icon: 'M12 3v6m0 0 3-3m-3 3-3-3M5 13h14v6a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-6Z'
  },
  {
    title: '끝까지 만든다',
    body: '코드가 아니라 제품을 납품합니다. 출시는 시작일 뿐 — 배포, 모니터링, 운영까지 책임지고 완성도를 끌어올립니다.',
    icon: 'M5 13l4 4L19 7'
  },
  {
    title: '기록하며 성장한다',
    body: '만들면서 배운 것을 기술 블로그와 오픈소스로 남깁니다. 기록은 다음 제품의 품질이 되고, 신뢰의 근거가 됩니다.',
    icon: 'M4 5a2 2 0 0 1 2-2h9l5 5v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5Zm11-2v5h5M8 13h8M8 17h5'
  }
];

const stats = [
  { label: '출시·운영 제품', value: '20+' },
  { label: '기술 아티클', value: '50+' },
  { label: '다루는 플랫폼', value: '4' }
];

const bizInfo = [
  { label: '상호', value: `${COMPANY.nameKo} (${COMPANY.nameEn})` },
  { label: '대표', value: COMPANY.ceo },
  { label: '사업자등록번호', value: COMPANY.bizNumber },
  { label: '이메일', value: COMPANY.email, href: `mailto:${COMPANY.email}` }
];
---

<Base
  title="회사 소개 | 토리스"
  description="토리스(Toris Inc.)는 거북이처럼 꾸준하게, 기획부터 출시·운영까지 제품을 완성하는 1인 소프트웨어 스튜디오입니다."
  path="/about"
  pageType="AboutPage"
  breadcrumbs={[{ name: '홈', url: '/' }, { name: '회사 소개' }]}
>
  <!-- ============================== Hero ============================== -->
  <section class="mx-auto max-w-6xl px-5 pb-20 pt-24 sm:pt-32">
    <div class="reveal max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-mint">About</p>
      <h1 class="mt-3 text-4xl font-extrabold leading-[1.12] tracking-tight text-ink sm:text-5xl">
        토리스를 소개합니다
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-muted">
        토리스는 웹·모바일·자동화 제품을 기획부터 출시, 운영까지 직접 만드는
        1인 소프트웨어 스튜디오입니다. 화려한 속도 대신 꾸준한 걸음을
        믿습니다. 거북이처럼 — 서두르지 않지만, 시작한 제품은 반드시 완성해서
        도착합니다.
      </p>
    </div>
  </section>

  <!-- ============================ Values ============================ -->
  <section class="border-t border-line bg-card">
    <div class="mx-auto max-w-6xl px-5 py-24">
      <div class="reveal max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-mint">Values</p>
        <h2 class="mt-3 text-3xl font-display text-ink sm:text-4xl">
          일하는 방식을 지키는 세 가지 원칙
        </h2>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {
          values.map((v, i) => (
            <article
              class="reveal group card-3d relative overflow-hidden border border-line bg-paper p-7 transition-[border-color] duration-300 hover:border-mint-deep"
              style={`transition-delay: ${i * 80}ms`}
            >
              <span class="flex size-12 items-center justify-center bg-mint/10 text-mint transition-colors group-hover:bg-mint group-hover:text-ink">
                <svg viewBox="0 0 24 24" class="size-6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={v.icon} />
                </svg>
              </span>
              <h3 class="mt-5 text-lg font-bold text-ink">{v.title}</h3>
              <p class="mt-2.5 text-[15px] leading-relaxed text-muted">{v.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- =========================== Mascot =========================== -->
  <section class="border-t border-line bg-card">
    <div class="mx-auto grid max-w-6xl items-center gap-12 px-5 py-24 lg:grid-cols-2">
      <div class="reveal flex justify-center">
        <!-- 거북이 등껍질 육각 마크 (Header 모노그램 확대·변형) -->
        <svg viewBox="0 0 240 240" class="w-56 sm:w-72" aria-hidden="true">
          <path
            d="M120 16 210 68v104L120 224 30 172V68L120 16Z"
            fill="none"
            stroke="#0f6a62"
            stroke-width="7"
            stroke-linejoin="round"></path>
          <path
            d="M120 62 158 84v44l-38 22-38-22V84l38-22Z"
            fill="#17a394"
            opacity="0.9"></path>
          <g fill="none" stroke="#17a394" stroke-width="4" stroke-linejoin="round" opacity="0.45">
            <path d="M120 62 158 84v44l-38 22-38-22V84l38-22Z"></path>
            <path d="M120 62V16M158 84l52-30M158 128l52 30M120 150v74M82 128l-52 30M82 84 30 54"></path>
          </g>
          <circle cx="120" cy="106" r="7" fill="#f59e0b"></circle>
        </svg>
      </div>
      <div class="reveal" style="transition-delay: 120ms">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-mint">Mascot</p>
        <h2 class="mt-3 text-3xl font-display text-ink sm:text-4xl">
          왜 거북이인가요?
        </h2>
        <div class="mt-6 space-y-4 text-[15px] leading-relaxed text-muted">
          <p>
            <strong class="font-bold text-ink">꾸준함.</strong>
            거북이는 멈추지 않습니다. 토리스도 매일의 커밋과 배포로 제품을
            조금씩, 그러나 반드시 앞으로 옮깁니다.
          </p>
          <p>
            <strong class="font-bold text-ink">방향.</strong>
            빠른 것보다 옳은 방향이 먼저입니다. 스코핑과 프로토타입으로 갈
            길을 확인한 뒤에 속도를 냅니다.
          </p>
          <p>
            <strong class="font-bold text-ink">등껍질.</strong>
            육각형이 맞물린 등껍질처럼, 견고한 설계 위에 기능을 쌓습니다.
            오래 운영해도 무너지지 않는 구조가 토리스의 자부심입니다.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ Stats ============================ -->
  <section class="border-t border-line bg-card">
    <div class="mx-auto max-w-6xl px-5 py-24">
      <div class="reveal max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-mint">Track record</p>
        <h2 class="mt-3 text-3xl font-display text-ink sm:text-4xl">
          무엇을 해왔나요?
        </h2>
      </div>
      <dl class="mt-12 grid gap-6 sm:grid-cols-3">
        {
          stats.map((s, i) => (
            <div
              class="card-3d relative overflow-hidden border border-line reveal bg-paper p-7 transition-[border-color] duration-300 hover:border-mint-deep"
              style={`transition-delay: ${i * 80}ms`}
            >
              <dt class="text-xs font-medium uppercase tracking-wider text-muted">{s.label}</dt>
              <dd class="mt-2 text-4xl font-extrabold tabular-nums text-ink">{s.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- ========================= Business info ========================= -->
  <section class="border-t border-line bg-card">
    <div class="mx-auto max-w-6xl px-5 py-24">
      <div class="reveal max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-mint">Company</p>
        <h2 class="mt-3 text-3xl font-display text-ink sm:text-4xl">
          믿고 맡기실 수 있도록
        </h2>
        <p class="mt-4 text-[15px] leading-relaxed text-muted">
          토리스는 정식으로 등록된 사업자입니다. 계약과 세금계산서 발행 모두
          가능합니다.
        </p>
      </div>
      <div
        class="reveal mt-10 max-w-2xl overflow-hidden border border-line bg-card"
        style="transition-delay: 120ms"
      >
        <div class="h-1 bg-mint" aria-hidden="true"></div>
        <dl class="divide-y divide-line">
          {
            bizInfo.map((row) => (
              <div class="flex flex-wrap items-baseline gap-x-6 gap-y-1 px-7 py-4">
                <dt class="w-32 shrink-0 text-sm font-semibold text-mint">{row.label}</dt>
                <dd class="text-[15px] font-medium text-ink">
                  {row.href ? (
                    <a
                      href={row.href}
                      class="hover:text-mint-bright hover:underline focus-visible:outline-2 focus-visible:outline-mint"
                    >
                      {row.value}
                    </a>
                  ) : (
                    row.value
                  )}
                </dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </section>

  <!-- =============================== CTA =============================== -->
  <section class="mx-auto max-w-6xl px-5 py-24">
    <div class="reveal rounded-3xl bg-paper-2 px-8 py-14 text-center sm:px-16">
      <h2 class="text-3xl font-display text-white">
        함께 만들어 볼까요?
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-ink-dim">
        아이디어 단계여도 괜찮습니다. 편하게 들려주세요 — 하루 안에 답장드립니다.
      </p>
      <a
        href="/contact"
        class="mt-8 inline-flex h-12 items-center gap-2 rounded-full bg-mint px-8 text-[15px] font-bold text-ink transition-all hover:-translate-y-0.5 hover:bg-mint-bright focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white active:translate-y-0"
      >
        프로젝트 문의하기
      </a>
    </div>
  </section>
  <CardFX />
</Base>
