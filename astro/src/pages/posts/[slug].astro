---
import { getCollection, render } from 'astro:content';
import AuthorByline from '../../components/AuthorByline.astro';
import Base from '../../layouts/Base.astro';
import { fileBaseName, formatDate, toISO, toPlainExcerpt } from '../../lib/slug';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Next와 동일한 제목 폴백: frontmatter title → 파일명
const title = post.data.title || fileBaseName(post.filePath) || post.id;
// Next generateMetadata와 동일한 폴백: frontmatter description → 정제 발췌
const description =
  post.data.description || toPlainExcerpt(post.body || '') ||
  '토리스의 기술 블로그 포스트입니다.';

// 카테고리 = markdown 하위 첫 디렉토리 (Next getCategoryFromPath와 동일)
const rel = (post.filePath || '').split('/markdown/')[1] || '';
const category = rel.includes('/') ? rel.split('/')[0] : 'Uncategorized';

const tags = Array.isArray(post.data.tags)
  ? post.data.tags
  : typeof post.data.tags === 'string'
    ? post.data.tags.split(',').map((t) => t.trim()).filter(Boolean)
    : [category];

const date = toISO(post.data.date);
const wordCount = (post.body || '').split(/\s+/).filter(Boolean).length;
---

<Base
  title={`${title} | 토리스 블로그`}
  description={description}
  path={`/posts/${post.id}`}
  ogType="article"
  article={{ headline: title, publishedAt: date, tags, category, wordCount }}
  breadcrumbs={[
    { name: '홈', url: '/' },
    { name: '블로그', url: '/blog' },
    { name: title }
  ]}
>
  <article class="mx-auto max-w-3xl px-5 py-14">
    <header class="reveal">
      <p class="flex flex-wrap items-center gap-2 text-sm">
        <a
          href="/blog"
          class="font-medium text-gold hover:underline focus-visible:outline-2 focus-visible:outline-gold"
        >
          ← 블로그
        </a>
        <span class="text-sand/70">·</span>
        <span
          class="rounded-full bg-gold/10 px-2.5 py-0.5 text-xs font-semibold text-gold"
        >
          {category}
        </span>
        {date && <time class="text-sand" datetime={date}>{formatDate(date)}</time>}
      </p>
      <h1
        class="mt-5 text-3xl font-display leading-snug text-ivory sm:text-4xl"
      >
        {title}
      </h1>
      {
        tags.length > 0 && (
          <p class="mt-4 flex flex-wrap gap-1.5">
            {tags.slice(0, 6).map((t) => (
              <span class="rounded-md border border-line bg-coal px-2 py-0.5 text-xs text-sand">
                #{t}
              </span>
            ))}
          </p>
        )
      }
      <AuthorByline variant="byline" date={date} dateLabel={formatDate(date)} />
    </header>

    <div class="prose-post mt-10">
      <Content />
    </div>

    <AuthorByline variant="bio" />

    <footer class="mt-14 border-t border-line pt-8">
      <div
        class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center"
      >
        <p class="text-sm text-sand">
          글이 도움이 됐다면, 프로젝트 이야기도 함께 나눠요.
        </p>
        <div class="flex gap-2">
          <a
            href="/contact"
            class="rounded-full bg-gold px-5 py-2.5 text-sm font-semibold text-night transition-colors hover:bg-gold-bright focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold"
          >
            문의하기
          </a>
          <a
            href="/blog"
            class="rounded-full border border-line px-5 py-2.5 text-sm font-semibold text-ivory-dim transition-colors hover:border-gold-deep hover:text-gold-bright focus-visible:outline-2 focus-visible:outline-gold"
          >
            다른 글 보기
          </a>
        </div>
      </div>
    </footer>
  </article>
</Base>
