---
import { getCollection } from 'astro:content';
import PostSearch, { type PostItem } from '../../components/PostSearch';
import Base from '../../layouts/Base.astro';
import { fileBaseName, formatDate, toPlainExcerpt } from '../../lib/slug';

const entries = await getCollection('posts');

const posts: PostItem[] = entries
  .map((post) => {
    const rel = (post.filePath || '').split('/markdown/')[1] || '';
    return {
      slug: post.id,
      title: post.data.title || fileBaseName(post.filePath) || post.id,
      description:
        post.data.description || toPlainExcerpt(post.body || '', 120),
      category: rel.includes('/') ? rel.split('/')[0] : 'Uncategorized',
      date: post.data.date || '',
      dateLabel: formatDate(post.data.date)
    };
  })
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Base
  title="기술 블로그 | 토리스"
  description="토리스가 제품을 만들고 운영하며 남긴 기록 — 웹, 모바일, AI 자동화, 인프라까지 실전 기술 노트."
  path="/blog"
>
  <section class="mx-auto max-w-3xl px-5 pb-20 pt-14">
    <header class="reveal">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-teal-700">
        Blog
      </p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-ink-900">
        만들면서 배운 것들
      </h1>
      <p class="mt-4 text-ink-500">
        제품을 만들고 운영하며 남긴 {posts.length}개의 기술 기록입니다.
      </p>
    </header>

    <div class="reveal mt-10">
      <PostSearch posts={posts} client:load />
    </div>
  </section>
</Base>
