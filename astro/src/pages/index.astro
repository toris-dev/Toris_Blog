---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import CardFX from '../components/CardFX.astro';
import LogoMark from '../components/LogoMark.astro';
import { COMPANY } from '../lib/site';
import { fileBaseName, formatDate, toPlainExcerpt } from '../lib/slug';
import { computeStats } from '../lib/stats';
import { projects } from '../../../src/data/projects';

const live = projects.filter((p) => p.status === '운영 중');
const featured = live.slice(0, 4);

const entries = await getCollection('posts');
const latestPosts = entries
  .map((post) => ({
    slug: post.id,
    title: post.data.title || fileBaseName(post.filePath) || post.id,
    description: post.data.description || toPlainExcerpt(post.body || '', 110),
    date: post.data.date || '',
    dateLabel: formatDate(post.data.date)
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);

// 신뢰 지표 — 단일 출처(lib/stats)에서 계산, 하드코딩 금지
const stats = computeStats(projects, entries.length);

// 오픈소스(npm) 제품 — 데이터에서 실제로 존재하는 것만
const oss = projects.filter((p) => /npm/i.test(`${p.platform} ${p.category}`));

const services = [
  {
    label: 'WEB · MOBILE',
    title: '웹 · 모바일 제품 개발',
    problem: '아이디어와 요구사항은 있는데, 끝까지 만들어 줄 팀이 없다.',
    outcome: '스토어와 브라우저에 실제로 올라가는 제품',
    scope: '기획 · 디자인 · 개발 · 배포 · 운영',
    href: '/contact',
    linkLabel: '프로젝트 이야기하기',
    demo: 'sync',
    wide: true
  },
  {
    label: 'MVP',
    title: 'MVP · 프로토타입',
    problem: '될지 안 될지, 시장에서 빠르게 검증이 필요하다.',
    outcome: '몇 주 안에 만질 수 있는 최소 제품',
    scope: '핵심 플로우 · 랜딩 · 검증 지표',
    href: '/process',
    linkLabel: '진행 방식 보기',
    demo: 'mvp',
    wide: false
  },
  {
    label: 'AUTOMATION',
    title: 'AI · 업무 자동화',
    problem: '반복 작업에 사람의 시간이 계속 새고 있다.',
    outcome: '수집 → 요약 → 발행까지 도는 파이프라인',
    scope: 'LLM 워크플로 · 봇 · 백오피스',
    href: '/contact',
    linkLabel: '자동화 상담하기',
    demo: 'pipe',
    wide: false
  }
] as const;

const steps = [
  {
    n: '01',
    t: '문의 · 상담',
    d: '만들고 싶은 것과 제약을 듣습니다.',
    out: '24시간 이내 1차 회신 · NDA 선택 가능'
  },
  {
    n: '02',
    t: '스코핑',
    d: '범위·일정·비용을 문서로 확정합니다.',
    out: '범위 문서 · 일정표 · 견적'
  },
  {
    n: '03',
    t: '설계 · 프로토타입',
    d: '만질 수 있는 초안으로 방향을 검증합니다.',
    out: '동작하는 프로토타입'
  },
  {
    n: '04',
    t: '개발 · 검증',
    d: '주 단위로 동작하는 결과물을 공유합니다.',
    out: '주간 데모 · 스테이징 환경 · 변경 이력'
  },
  {
    n: '05',
    t: '출시 · 운영',
    d: '배포 후에도 지표와 함께 개선을 잇습니다.',
    out: '배포 · 모니터링 · 개선 사이클'
  }
] as const;

// 등껍질 6셀 — 거북이 브랜드의 재해석(각 셀 = 제품을 완성하는 축)
const shellCells = [
  { k: 'Strategy', ko: '전략' },
  { k: 'Design', ko: '설계' },
  { k: 'Engineering', ko: '구현' },
  { k: 'Launch', ko: '출시' },
  { k: 'Operations', ko: '운영' },
  { k: 'Learning', ko: '학습' }
] as const;

// 서비스 링크(웹사이트·스토어·릴리스 다운로드)만 클릭 허용.
const isServiceLink = (url: string) =>
  !url.startsWith('https://github.com/') || /\/releases\/?$/.test(url);
---

<Base
  title="토리스 (Toris Inc.) — 아이디어를 출시 가능한 제품으로"
  description={COMPANY.description}
  path="/"
>
  <!-- ============================== Hero ============================== -->
  <section id="hero" class="relative overflow-hidden">
    <canvas
      id="shell-canvas"
      class="pointer-events-none absolute inset-0 h-full w-full"
      aria-hidden="true"></canvas>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-paper to-transparent"
      aria-hidden="true"
    >
    </div>

    <div
      class="relative mx-auto grid min-h-[calc(100dvh-4rem)] max-w-6xl content-center gap-12 px-5 py-24 lg:grid-cols-[7fr_5fr] lg:items-center"
    >
      <div>
        <p class="hero-in font-mono text-[11px] font-medium tracking-[0.28em] text-mint-deep">
          PRODUCT ENGINEERING STUDIO · SEOUL
        </p>

        <h1
          class="hero-in font-display mt-7 max-w-4xl break-keep text-[clamp(2.6rem,7.5vw,5.5rem)] leading-[1.08] text-ink"
          style="transition-delay: 120ms"
        >
          서두르지 않되,<br />
          반드시 <span class="text-mint-deep">출시</span>합니다
        </h1>

        <p
          class="hero-in mt-7 max-w-xl break-keep text-base leading-relaxed text-ink-dim sm:text-lg"
          style="transition-delay: 240ms"
        >
          토리스는 웹·모바일·AI 자동화 제품을 기획부터 출시와 운영까지 책임지는
          소프트웨어 스튜디오입니다. 거북이의 걸음으로 — 조용히, 그러나 멈추지
          않고.
        </p>

        <div class="hero-in mt-10 flex flex-wrap items-center gap-4" style="transition-delay: 360ms">
          <a
            href="/contact"
            class="inline-flex h-12 items-center gap-3 rounded-lg bg-ink px-7 text-[15px] font-semibold text-paper transition-all duration-300 hover:-translate-y-0.5 hover:bg-mint-deep hover:shadow-[0_10px_28px_-10px_color-mix(in_srgb,var(--color-mint)_55%,transparent)] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-mint-deep active:translate-y-0"
          >
            프로젝트 이야기하기
            <svg viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
              <path d="M5 12h14m-6-6 6 6-6 6"></path>
            </svg>
          </a>
          <a
            href="/projects"
            class="inline-flex h-12 items-center gap-2 rounded-lg border border-line bg-card px-6 text-[15px] font-medium text-ink-dim transition-all duration-300 hover:border-mint hover:text-ink focus-visible:outline-2 focus-visible:outline-mint-deep"
          >
            만든 제품 살펴보기
          </a>
        </div>

        <!-- 배포 흐름 라인 — 커밋 점이 천천히 이동 -->
        <div class="hero-in mt-14 max-w-xl" style="transition-delay: 480ms" aria-hidden="true">
          <div class="pipe relative h-px bg-line">
            <span class="pipe-dot"></span>
          </div>
          <div class="mt-2 flex justify-between font-mono text-[10px] tracking-[0.18em] text-muted">
            <span>COMMIT</span><span>BUILD</span><span>DEPLOY</span><span>OPERATE</span>
          </div>
        </div>
      </div>

      <!-- 플로팅 제품 패널 — 실제 운영 데이터만 표기 -->
      <div id="hero-panels" class="relative hidden h-[420px] select-none lg:block" aria-hidden="true">
        <!-- 배포 상태 패널 -->
        <div class="float-panel glass absolute right-2 top-2 w-64 rounded-xl p-4" data-depth="14">
          <p class="font-mono text-[10px] tracking-[0.2em] text-muted">DEPLOYMENTS</p>
          <ul class="mt-3 space-y-2.5">
            <li class="flex items-center justify-between text-[13px]">
              <span class="font-medium text-ink">catchmeme.com</span>
              <span class="flex items-center gap-1.5 text-live"><span class="size-1.5 rounded-full bg-live"></span>Live</span>
            </li>
            <li class="flex items-center justify-between text-[13px]">
              <span class="font-medium text-ink">toris.kr</span>
              <span class="flex items-center gap-1.5 text-live"><span class="size-1.5 rounded-full bg-live"></span>Live</span>
            </li>
            <li class="flex items-center justify-between text-[13px]">
              <span class="font-medium text-ink">asyncraft</span>
              <span class="font-mono text-[11px] text-muted">npm</span>
            </li>
          </ul>
        </div>
        <!-- 터미널 패널 -->
        <div class="float-panel glass absolute bottom-14 left-0 w-72 rounded-xl p-4 font-mono text-[12px] leading-6" data-depth="26" style="animation-delay: 1.2s">
          <p class="text-muted">$ pnpm run deploy</p>
          <p class="text-ink-dim">✓ 30 pages built</p>
          <p class="text-mint-deep">▲ deployed to production</p>
        </div>
        <!-- 육각 마크 -->
        <div class="float-panel absolute bottom-0 right-10" data-depth="8" style="animation-delay: 0.6s">
          <LogoMark class="size-24 opacity-80" />
        </div>
      </div>
    </div>
  </section>

  <!-- ========================= 신뢰 지표(계산값) ========================= -->
  <section class="border-y border-line bg-card">
    <dl class="mx-auto grid max-w-6xl grid-cols-2 gap-x-6 gap-y-8 px-5 py-12 sm:grid-cols-4">
      <div class="reveal">
        <dd class="font-display text-4xl text-ink">
          <span data-count={String(stats.live)}>{stats.live}</span>
        </dd>
        <dt class="mt-1 font-mono text-[11px] tracking-[0.18em] text-muted">운영 중 제품</dt>
      </div>
      <div class="reveal" style="transition-delay: 70ms">
        <dd class="font-display text-4xl text-ink">
          <span data-count={String(stats.total)}>{stats.total}</span>
        </dd>
        <dt class="mt-1 font-mono text-[11px] tracking-[0.18em] text-muted">누적 프로젝트</dt>
      </div>
      <div class="reveal" style="transition-delay: 140ms">
        <dd class="font-display text-4xl text-ink">
          <span data-count={String(stats.posts)}>{stats.posts}</span>
        </dd>
        <dt class="mt-1 font-mono text-[11px] tracking-[0.18em] text-muted">기술 기록</dt>
      </div>
      <div class="reveal" style="transition-delay: 210ms">
        <dd class="font-display text-4xl text-ink">{stats.firstReply}</dd>
        <dt class="mt-1 font-mono text-[11px] tracking-[0.18em] text-muted">첫 회신</dt>
      </div>
    </dl>
  </section>

  <!-- ============================ Services ============================ -->
  <section class="mx-auto max-w-6xl px-5 py-24 sm:py-28">
    <div class="reveal grid gap-6 md:grid-cols-[1fr_2fr]">
      <div>
        <p class="font-mono text-[11px] font-medium tracking-[0.28em] text-mint-deep">SERVICES</p>
        <h2 class="font-display mt-4 text-3xl leading-snug text-ink sm:text-4xl">
          작게 시작해서,<br />끝까지 만듭니다
        </h2>
      </div>
      <p class="self-end break-keep text-[15px] leading-relaxed text-ink-dim md:max-w-md md:justify-self-end">
        외주가 아니라 제품을 함께 만드는 파트너로 일합니다. 계약보다 결과물이,
        말보다 배포가 먼저입니다.
      </p>
    </div>

    <div class="mt-12 grid gap-4 md:grid-cols-3">
      {
        services.map((s, i) => (
          <article
            class:list={[
              'reveal group relative flex flex-col overflow-hidden rounded-xl border border-line bg-card p-7 transition-all duration-300 hover:border-mint hover:shadow-[0_16px_40px_-24px_color-mix(in_srgb,var(--color-ink)_35%,transparent)] sm:p-8',
              s.wide && 'md:col-span-2'
            ]}
            style={`transition-delay: ${i * 90}ms`}
          >
            <span class="font-mono text-[10px] font-medium tracking-[0.24em] text-mint-deep">
              {s.label}
            </span>
            <h3 class="font-display mt-4 text-2xl text-ink">{s.title}</h3>

            <!-- 미니 데모 -->
            {s.demo === 'sync' && (
              <div class="demo-sync mt-6 flex items-center gap-3" aria-hidden="true">
                <div class="w-40 rounded-lg border border-line bg-paper p-2">
                  <div class="flex gap-1"><i class="size-1.5 rounded-full bg-line" /><i class="size-1.5 rounded-full bg-line" /><i class="size-1.5 rounded-full bg-line" /></div>
                  <div class="mt-2 space-y-1.5">
                    <div class="demo-bar h-1.5 w-4/5 rounded bg-mint/40" />
                    <div class="demo-bar h-1.5 w-3/5 rounded bg-line" style="transition-delay:80ms" />
                    <div class="demo-bar h-1.5 w-2/3 rounded bg-line" style="transition-delay:160ms" />
                  </div>
                </div>
                <div class="demo-link h-px flex-1 bg-line" />
                <div class="w-14 rounded-lg border border-line bg-paper p-1.5">
                  <div class="mx-auto h-16 w-full rounded border border-line bg-card p-1">
                    <div class="demo-bar h-1 w-full rounded bg-mint/40" />
                    <div class="demo-bar mt-1 h-1 w-2/3 rounded bg-line" style="transition-delay:120ms" />
                  </div>
                </div>
              </div>
            )}
            {s.demo === 'mvp' && (
              <div class="demo-mvp mt-6 grid grid-cols-3 gap-2" aria-hidden="true">
                <div class="demo-block h-14 rounded-lg border border-dashed border-line" />
                <div class="demo-block h-14 rounded-lg border border-dashed border-line" style="transition-delay:100ms" />
                <div class="demo-block h-14 rounded-lg border border-dashed border-line" style="transition-delay:200ms" />
              </div>
            )}
            {s.demo === 'pipe' && (
              <div class="demo-pipe mt-6" aria-hidden="true">
                <div class="relative flex items-center justify-between">
                  <span class="pipe-node">수집</span>
                  <span class="pipe-node">요약</span>
                  <span class="pipe-node">발행</span>
                  <i class="absolute inset-x-8 top-1/2 -z-10 h-px bg-line" />
                  <i class="pipe-runner" />
                </div>
              </div>
            )}

            <dl class="mt-6 space-y-2.5 text-sm">
              <div class="flex gap-3">
                <dt class="w-12 shrink-0 font-mono text-[10px] leading-6 tracking-[0.16em] text-muted">문제</dt>
                <dd class="break-keep text-ink-dim">{s.problem}</dd>
              </div>
              <div class="flex gap-3">
                <dt class="w-12 shrink-0 font-mono text-[10px] leading-6 tracking-[0.16em] text-muted">결과물</dt>
                <dd class="break-keep font-medium text-ink">{s.outcome}</dd>
              </div>
              <div class="flex gap-3">
                <dt class="w-12 shrink-0 font-mono text-[10px] leading-6 tracking-[0.16em] text-muted">범위</dt>
                <dd class="text-ink-dim">{s.scope}</dd>
              </div>
            </dl>

            <a
              href={s.href}
              class="mt-auto inline-flex items-center gap-1.5 pt-6 text-sm font-semibold text-mint-deep transition-colors hover:text-mint focus-visible:outline-2 focus-visible:outline-mint-deep"
            >
              {s.linkLabel}
              <svg viewBox="0 0 24 24" class="size-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                <path d="M5 12h14m-6-6 6 6-6 6"></path>
              </svg>
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ============================== Work ============================== -->
  <section class="border-y border-line bg-paper-2/60">
    <div class="mx-auto max-w-6xl px-5 py-24 sm:py-28">
      <div class="reveal flex flex-wrap items-end justify-between gap-6">
        <div>
          <p class="font-mono text-[11px] font-medium tracking-[0.28em] text-mint-deep">WORK</p>
          <h2 class="font-display mt-4 text-3xl leading-snug text-ink sm:text-4xl">
            직접 만들어 운영하는 제품
          </h2>
        </div>
        <a
          href="/projects"
          class="border-b border-transparent pb-1 text-sm font-medium text-ink-dim transition-colors hover:border-mint hover:text-ink focus-visible:outline-2 focus-visible:outline-mint-deep"
        >
          전체 보기 →
        </a>
      </div>

      <div class="mt-12 grid gap-4 sm:grid-cols-2">
        {
          featured.map((p, i) => { const linked = isServiceLink(p.github); const Tag = linked ? 'a' : 'div'; return (
            <Tag
              href={linked ? p.github : undefined}
              target={linked ? '_blank' : undefined}
              rel={linked ? 'noopener noreferrer' : undefined}
              class="card-3d reveal group relative flex flex-col overflow-hidden rounded-xl border border-line bg-card transition-[border-color,box-shadow] duration-300 hover:border-mint hover:shadow-[0_16px_40px_-24px_color-mix(in_srgb,var(--color-ink)_35%,transparent)] focus-visible:outline-2 focus-visible:outline-mint-deep"
              style={`transition-delay: ${i * 80}ms`}
            >
              <span class="card-glare" aria-hidden="true" />
              <!-- 제품 프레임(브라우저 크롬) -->
              <div class="border-b border-line bg-paper px-4 py-2.5" aria-hidden="true">
                <div class="flex items-center gap-2">
                  <span class="flex gap-1"><i class="size-2 rounded-full bg-line" /><i class="size-2 rounded-full bg-line" /><i class="size-2 rounded-full bg-line" /></span>
                  <span class="ml-2 truncate rounded bg-card px-2 py-0.5 font-mono text-[10px] text-muted">
                    {linked ? p.github.replace(/^https?:\/\//, '').replace(/\/$/, '') : p.platform}
                  </span>
                </div>
              </div>
              <div class="flex grow flex-col p-6">
                <div class="flex items-baseline justify-between gap-3">
                  <h3 class="font-display text-2xl text-ink">{p.name}</h3>
                  <span class="font-mono text-[10px] tracking-[0.14em] text-muted">{p.year}</span>
                </div>
                <p class="mt-1 font-mono text-[10px] tracking-[0.18em] text-muted uppercase">{p.category} · {p.platform}</p>
                <p class="mt-3 break-keep text-sm leading-relaxed text-ink-dim">{p.tagline}</p>
                <p class="mt-4 text-xs tracking-wide text-muted">{p.tech.slice(0, 5).join(' · ')}</p>
                <div class="mt-auto flex items-center justify-between gap-3 pt-6">
                  <span class="flex items-center gap-2 text-[11px] tracking-wider text-live">
                    <span class="size-1.5 rounded-full bg-live" aria-hidden="true" />
                    {p.status} · 기획부터 운영까지
                  </span>
                  {linked && (
                    <span class="flex items-center gap-1.5 text-[13px] font-medium text-muted transition-colors duration-300 group-hover:text-mint-deep">
                      서비스 열기
                      <svg viewBox="0 0 24 24" class="size-3.5 transition-transform duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M7 17 17 7M9 7h8v8" />
                      </svg>
                    </span>
                  )}
                </div>
              </div>
              <span class="absolute -bottom-px left-0 h-0.5 w-0 bg-mint transition-all duration-500 group-hover:w-full" aria-hidden="true" />
            </Tag>
          ); })
        }
      </div>
    </div>
  </section>

  <!-- ============================= Process ============================ -->
  <section class="mx-auto max-w-6xl px-5 py-24 sm:py-28">
    <div class="reveal max-w-2xl">
      <p class="font-mono text-[11px] font-medium tracking-[0.28em] text-mint-deep">PROCESS</p>
      <h2 class="font-display mt-4 text-3xl leading-snug text-ink sm:text-4xl">
        다섯 걸음이면 충분합니다
      </h2>
    </div>

    <div class="mt-14 grid gap-10 md:grid-cols-[1fr_2fr]">
      <!-- 좌: 현재 단계 sticky -->
      <div class="hidden md:block">
        <div class="sticky top-28">
          <p id="process-now-n" class="font-display text-7xl text-mint/50 transition-all duration-300">01</p>
          <p id="process-now-t" class="font-display mt-2 text-xl text-ink">문의 · 상담</p>
          <span class="rule-accent mt-5 block w-14" aria-hidden="true"></span>
        </div>
      </div>

      <!-- 우: 진행선 + 단계 -->
      <ol id="process-list" class="relative space-y-4 border-l border-line pl-8 md:pl-10">
        <span
          id="process-fill"
          class="absolute -left-px top-0 w-px bg-mint transition-[height] duration-300"
          style="height: 0%"
          aria-hidden="true"></span>
        {
