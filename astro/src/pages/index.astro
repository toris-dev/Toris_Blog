---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { COMPANY } from '../lib/site';
import { fileBaseName, formatDate, toPlainExcerpt } from '../lib/slug';
import { projects } from '../../../src/data/projects';

const featured = projects.filter((p) => p.status === '운영 중').slice(0, 4);

const entries = await getCollection('posts');
const latestPosts = entries
  .map((post) => ({
    slug: post.id,
    title: post.data.title || fileBaseName(post.filePath) || post.id,
    description: post.data.description || toPlainExcerpt(post.body || '', 110),
    date: post.data.date || '',
    dateLabel: formatDate(post.data.date)
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
const [headPost, ...restPosts] = latestPosts;

const services = [
  {
    title: '웹 · 모바일 제품 개발',
    body: 'Next.js·Astro 웹부터 Flutter·React Native 앱까지 — 아이디어를 스토어와 브라우저에 올라가는 제품으로 만듭니다. 기획, 디자인, 개발, 배포를 한 사람이 끝까지 책임집니다.',
    label: '웹 · 앱',
    wide: true
  },
  {
    title: 'MVP · 프로토타입',
    body: '검증이 필요한 아이디어를 몇 주 안에 만질 수 있는 형태로. 작게 만들어 빠르게 배웁니다.',
    label: 'MVP',
    wide: false
  },
  {
    title: 'AI · 업무 자동화',
    body: '수집·요약·발행 파이프라인, LLM 에이전트 워크플로 — 반복 업무를 소프트웨어로 대체합니다.',
    label: '자동화',
    wide: false
  }
];

const steps = [
  { n: '01', t: '문의 · 상담', d: '만들고 싶은 것과 제약을 듣습니다.' },
  { n: '02', t: '스코핑', d: '범위·일정·비용을 문서로 확정합니다.' },
  { n: '03', t: '설계 · 프로토타입', d: '만질 수 있는 초안으로 방향을 검증합니다.' },
  { n: '04', t: '개발 · 검증', d: '주 단위로 동작하는 결과물을 공유합니다.' },
  { n: '05', t: '출시 · 운영', d: '배포 후에도 지표와 함께 개선을 잇습니다.' }
];
---

<Base
  title="토리스 (Toris Inc.) — 꾸준함이 완성하는 소프트웨어"
  description={COMPANY.description}
  path="/"
>
  <!-- ============================== Hero ============================== -->
  <section class="relative overflow-hidden">
    <canvas
      id="shell-canvas"
      class="pointer-events-none absolute inset-0 h-full w-full"
      aria-hidden="true"></canvas>
    <!-- 하단 페이드 -->
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-night to-transparent"
      aria-hidden="true"
    >
    </div>

    <div
      class="relative mx-auto flex min-h-[calc(100dvh-4rem)] max-w-6xl flex-col justify-center px-5 py-24"
    >
      <div class="hero-in flex items-center gap-4">
        <span class="rule-gold w-16 sm:w-24" aria-hidden="true"></span>
        <p class="text-xs font-semibold tracking-[0.35em] text-gold break-keep">
          TORIS INC. — 1인 소프트웨어 스튜디오
        </p>
      </div>

      <h1
        class="hero-in font-display mt-8 max-w-4xl break-keep text-[clamp(2.75rem,9vw,6.5rem)] leading-[1.06] text-ivory"
        style="transition-delay: 120ms"
      >
        서두르지 않되,<br />
        <span class="text-gold">반드시 완성</span>합니다
      </h1>

      <p
        class="hero-in mt-8 max-w-xl break-keep text-base leading-relaxed text-ivory-dim sm:text-lg"
        style="transition-delay: 240ms"
      >
        토리스는 웹·모바일·자동화 제품을 기획부터 출시, 운영까지 혼자서 끝까지
        만드는 개인사업 스튜디오입니다. 거북이의 걸음으로 — 조용히, 그러나
        멈추지 않고.
      </p>

      <div class="hero-in mt-12 flex flex-wrap items-center gap-4" style="transition-delay: 360ms">
        <a
          href="/contact"
          class="inline-flex h-12 items-center gap-3 rounded-none border border-gold bg-gold px-8 text-[15px] font-semibold text-night transition-all duration-300 hover:-translate-y-0.5 hover:bg-gold-bright hover:shadow-[0_8px_32px_-8px_rgba(201,169,106,0.5)] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-gold active:translate-y-0"
        >
          프로젝트 문의
          <svg viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
            <path d="M5 12h14m-6-6 6 6-6 6"></path>
          </svg>
        </a>
        <a
          href="/projects"
          class="inline-flex h-12 items-center border-b border-transparent px-2 text-[15px] font-medium text-ivory-dim transition-colors hover:border-gold hover:text-ivory focus-visible:outline-2 focus-visible:outline-gold"
        >
          만든 제품 보기 →
        </a>
      </div>

      <!-- 오프셋 스탯 스트립 — 비대칭 배치 -->
      <dl
        class="hero-in mt-20 flex max-w-2xl flex-wrap gap-x-14 gap-y-6 border-l border-line pl-6 sm:ml-24 sm:mt-24"
        style="transition-delay: 480ms"
      >
        <div>
          <dd class="font-display text-4xl text-ivory sm:text-5xl">
            <span data-count={String(projects.length)}>0</span><span class="text-gold">+</span>
          </dd>
          <dt class="mt-1 text-xs tracking-wider text-sand">출시·운영 제품</dt>
        </div>
        <div>
          <dd class="font-display text-4xl text-ivory sm:text-5xl">
            <span data-count={String(entries.length)}>0</span>
          </dd>
          <dt class="mt-1 text-xs tracking-wider text-sand">기술 기록</dt>
        </div>
        <div>
          <dd class="font-display text-4xl text-ivory sm:text-5xl">
            <span data-count="4">0</span>
          </dd>
          <dt class="mt-1 text-xs tracking-wider text-sand">플랫폼</dt>
        </div>
      </dl>
    </div>
  </section>

  <!-- ============================ Services ============================ -->
  <section class="mx-auto max-w-6xl px-5 py-28 sm:py-32">
    <div class="reveal grid gap-6 md:grid-cols-[1fr_2fr]">
      <div>
        <p class="text-xs font-semibold tracking-[0.35em] text-gold">WHAT WE DO</p>
        <h2 class="font-display mt-4 text-3xl leading-snug text-ivory sm:text-4xl">
          작게 시작해서,<br />끝까지 만듭니다
        </h2>
      </div>
      <p class="self-end text-[15px] leading-relaxed text-sand md:max-w-md md:justify-self-end">
        외주가 아니라 제품을 함께 만드는 파트너로 일합니다. 계약보다 결과물이,
        말보다 배포가 먼저입니다.
      </p>
    </div>

    <!-- 크기 대비: 첫 카드가 2열을 차지 -->
    <div class="mt-14 grid gap-4 md:grid-cols-3">
      {
        services.map((s, i) => (
          <article
            class:list={[
              'reveal group relative overflow-hidden border border-line bg-coal p-8 transition-all duration-300 hover:border-gold-deep hover:bg-coal-2 sm:p-10',
              s.wide && 'md:col-span-2'
            ]}
            style={`transition-delay: ${i * 90}ms`}
          >
            <span class="text-xs font-semibold tracking-[0.3em] text-gold/80">
              {s.label}
            </span>
            <h3 class="font-display mt-5 text-2xl text-ivory sm:text-[1.75rem]">
              {s.title}
            </h3>
            <p class="mt-4 max-w-lg text-[15px] leading-relaxed text-sand">
              {s.body}
            </p>
            <span
              class="absolute -bottom-px left-0 h-px w-0 bg-gold transition-all duration-500 group-hover:w-full"
              aria-hidden="true"
            />
          </article>
        ))
      }
    </div>
  </section>

  <!-- ================= 시그니처 풀쿼트 — 금박 육각 ================= -->
  <section class="relative overflow-hidden border-y border-line bg-coal">
    <svg
      viewBox="0 0 48 48"
      class="pointer-events-none absolute -right-24 top-1/2 h-[420px] w-[420px] -translate-y-1/2 opacity-[0.07] sm:h-[560px] sm:w-[560px]"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M24 3.5 41.5 13.6v20.8L24 44.5 6.5 34.4V13.6L24 3.5Z"
        stroke="#c9a96a"
        stroke-width="0.8"></path>
      <path
        d="M24 12.5 31 16.6v8.2l-7 4.1-7-4.1v-8.2l7-4.1Z"
        stroke="#c9a96a"
        stroke-width="0.6"></path>
    </svg>
    <div class="relative mx-auto max-w-6xl px-5 py-28 sm:py-36">
      <blockquote class="reveal max-w-3xl">
        <p class="font-display text-[clamp(1.75rem,5vw,3.25rem)] leading-[1.35] text-ivory">
          "느린 걸음을 부끄러워한 적 없습니다.<br class="hidden sm:block" />
          <span class="text-gold">멈춘 적이 없기</span> 때문입니다."
        </p>
        <footer class="mt-8 flex items-center gap-4">
          <span class="rule-gold w-12" aria-hidden="true"></span>
          <cite class="text-sm not-italic tracking-wider text-sand">
            {COMPANY.ceo} — 토리스 대표
          </cite>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- ============================ Products ============================ -->
  <section class="mx-auto max-w-6xl px-5 py-28 sm:py-32">
    <div class="reveal flex flex-wrap items-end justify-between gap-6">
      <div>
        <p class="text-xs font-semibold tracking-[0.35em] text-gold">PRODUCTS</p>
        <h2 class="font-display mt-4 text-3xl leading-snug text-ivory sm:text-4xl">
          직접 만들어 운영하는 제품
        </h2>
      </div>
      <a
        href="/projects"
        class="border-b border-transparent pb-1 text-sm font-medium text-ivory-dim transition-colors hover:border-gold hover:text-ivory focus-visible:outline-2 focus-visible:outline-gold"
      >
        전체 보기 →
      </a>
    </div>

    <!-- 위계: 첫 제품 크게, 나머지 3개 컴팩트 -->
    <div class="mt-14 grid gap-4 md:grid-cols-3">
      {
        featured.map((p, i) => (
          <a
            href={p.github}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              'reveal group relative overflow-hidden border border-line bg-coal transition-all duration-300 hover:-translate-y-1 hover:border-gold-deep focus-visible:outline-2 focus-visible:outline-gold',
              i === 0 ? 'p-8 md:col-span-2 md:row-span-2 md:p-12' : 'p-7'
            ]}
            style={`transition-delay: ${i * 80}ms`}
          >
            <div class="flex items-start justify-between gap-3">
              <h3
                class:list={[
                  'font-display text-ivory',
                  i === 0 ? 'text-3xl sm:text-4xl' : 'text-xl'
                ]}
              >
                {p.name}
              </h3>
              <span class="flex items-center gap-1.5 whitespace-nowrap text-[11px] tracking-wider text-live">
                <span class="size-1.5 rounded-full bg-live" aria-hidden="true" />
                {p.status}
              </span>
            </div>
            <p class="mt-1.5 text-xs tracking-wider text-sand">{p.category}</p>
            <p
              class:list={[
                'mt-4 leading-relaxed text-ivory-dim',
                i === 0 ? 'max-w-md text-base' : 'line-clamp-2 text-sm'
              ]}
            >
              {p.tagline}
            </p>
            {i === 0 && (
              <p class="mt-8 flex flex-wrap gap-2">
                {p.tech.slice(0, 5).map((t) => (
                  <span class="border border-line px-2.5 py-1 text-[11px] text-sand">
                    {t}
                  </span>
                ))}
              </p>
            )}
            <span
              class="absolute -bottom-px left-0 h-px w-0 bg-gold transition-all duration-500 group-hover:w-full"
              aria-hidden="true"
            />
          </a>
        ))
      }
    </div>
  </section>

  <!-- ============================= Process ============================ -->
  <section class="border-y border-line bg-coal">
    <div class="mx-auto max-w-6xl px-5 py-28 sm:py-32">
      <div class="reveal max-w-2xl">
        <p class="text-xs font-semibold tracking-[0.35em] text-gold">PROCESS</p>
        <h2 class="font-display mt-4 text-3xl leading-snug text-ivory sm:text-4xl">
          다섯 걸음이면 충분합니다
        </h2>
      </div>
      <ol class="mt-16 grid gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-5">
        {
          steps.map((s, i) => (
            <li class="reveal relative" style={`transition-delay: ${i * 70}ms`}>
              <span class="font-display text-4xl text-gold/40">{s.n}</span>
              <span class="rule-gold mt-3 block w-10" aria-hidden="true" />
              <h3 class="mt-4 font-semibold text-ivory">{s.t}</h3>
              <p class="mt-2 text-sm leading-relaxed text-sand">{s.d}</p>
            </li>
          ))
        }
      </ol>
      <p class="reveal mt-12">
        <a
          href="/process"
          class="border-b border-transparent pb-1 text-sm font-medium text-ivory-dim transition-colors hover:border-gold hover:text-ivory focus-visible:outline-2 focus-visible:outline-gold"
        >
          진행 방식 자세히 보기 →
        </a>
      </p>
    </div>
  </section>

  <!-- ============================== Blog ============================== -->
  <section class="mx-auto max-w-6xl px-5 py-28 sm:py-32">
    <div class="reveal flex flex-wrap items-end justify-between gap-6">
      <div>
        <p class="text-xs font-semibold tracking-[0.35em] text-gold">JOURNAL</p>
        <h2 class="font-display mt-4 text-3xl leading-snug text-ivory sm:text-4xl">
          만들면서 배운 것들
        </h2>
      </div>
      <a
        href="/blog"
        class="border-b border-transparent pb-1 text-sm font-medium text-ivory-dim transition-colors hover:border-gold hover:text-ivory focus-visible:outline-2 focus-visible:outline-gold"
      >
        블로그 전체 →
      </a>
    </div>

    <!-- 위계: 최신 글 크게 + 나머지 리스트 -->
    <div class="mt-14 grid gap-10 md:grid-cols-[3fr_2fr] md:gap-16">
      {
        headPost && (
          <a
            href={`/posts/${encodeURIComponent(headPost.slug)}`}
            class="reveal group block focus-visible:outline-2 focus-visible:outline-gold"
          >
            {headPost.dateLabel && (
              <time datetime={headPost.date} class="text-xs tracking-wider text-sand">
                {headPost.dateLabel}
              </time>
            )}
            <h3 class="font-display mt-3 text-2xl leading-snug text-ivory transition-colors group-hover:text-gold sm:text-3xl">
              {headPost.title}
            </h3>
            <p class="mt-4 max-w-lg leading-relaxed text-sand">
              {headPost.description}
            </p>
            <span class="mt-6 inline-block border-b border-gold pb-0.5 text-sm text-gold">
              읽기 →
            </span>
          </a>
        )
      }
      <div class="flex flex-col justify-center gap-2">
        {
          restPosts.map((post, i) => (
            <a
              href={`/posts/${encodeURIComponent(post.slug)}`}
              class="reveal group border-t border-line py-6 first:border-t-0 focus-visible:outline-2 focus-visible:outline-gold"
              style={`transition-delay: ${(i + 1) * 90}ms`}
            >
              {post.dateLabel && (
                <time datetime={post.date} class="text-xs tracking-wider text-sand">
                  {post.dateLabel}
                </time>
              )}
              <h3 class="mt-2 line-clamp-2 font-semibold leading-snug text-ivory-dim transition-colors group-hover:text-ivory">
                {post.title}
              </h3>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- =============================== CTA =============================== -->
  <section class="relative overflow-hidden border-t border-line bg-coal">
    <div class="relative mx-auto max-w-6xl px-5 py-28 text-center sm:py-32">
      <p class="reveal text-xs font-semibold tracking-[0.35em] text-gold">CONTACT</p>
      <h2 class="reveal font-display mx-auto mt-6 max-w-2xl text-[clamp(2rem,5.5vw,3.5rem)] leading-[1.2] text-ivory">
        만들고 싶은 것이 있다면,<br />이야기를 들려주세요
      </h2>
      <p class="reveal mx-auto mt-6 max-w-md text-ivory-dim">
        아이디어 단계여도 좋습니다. 하루 안에 답장드립니다.
      </p>
      <div class="reveal mt-12">
        <a
          href="/contact"
          class="inline-flex h-14 items-center gap-3 border border-gold bg-gold px-10 text-base font-semibold text-night transition-all duration-300 hover:-translate-y-0.5 hover:bg-gold-bright hover:shadow-[0_8px_32px_-8px_rgba(201,169,106,0.5)] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-gold active:translate-y-0"
        >
          문의하기
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero-in {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
  }
  :global(body.hero-ready) .hero-in {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-in {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  requestAnimationFrame(() => document.body.classList.add('hero-ready'));

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ---------- 숫자 카운트업 ----------
  document.querySelectorAll<HTMLElement>('[data-count]').forEach((el) => {
    const target = Number(el.dataset.count || '0');
    if (reduce) {
      el.textContent = String(target);
      return;
    }
    const t0 = performance.now();
    const dur = 1400;
    const tick = (now: number) => {
      const p = Math.min(1, (now - t0) / dur);
      el.textContent = String(Math.round(target * (1 - Math.pow(1 - p, 3))));
      if (p < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  });

  // ---------- 금박 육각 등껍질 캔버스 ----------
  const canvas = document.getElementById('shell-canvas') as HTMLCanvasElement | null;
  const section = canvas?.parentElement;
  const ctx = canvas?.getContext('2d');
  if (canvas && ctx && section) {
    // 토큰: --color-gold(#c9a96a), --color-gold-bright(#e3c98f)
    const GOLD = [201, 169, 106];
    const GOLD_BRIGHT = [227, 201, 143];
    let W = 0;
    let H = 0;
    let dpr = 1;
    let raf = 0;
    let running = false;
    type Cell = { x: number; y: number; heat: number; phase: number };
    let cells: Cell[] = [];
    const mouse = { x: -9999, y: -9999 };
    const R = 44;

    const build = () => {
      const rect = section.getBoundingClientRect();
      W = rect.width;
      H = rect.height;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.round(W * dpr);
      canvas.height = Math.round(H * dpr);
      cells = [];
      const dx = R * 1.732;
      const dy = R * 1.5;
      for (let row = 0; row * dy < H + R; row++) {
        for (let col = 0; col * dx < W + R; col++) {
          cells.push({
            x: col * dx + (row % 2 ? dx / 2 : 0),
            y: row * dy,
            heat: 0,
            phase: Math.random() * Math.PI * 2
          });
        }
      }
    };

    const hex = (x: number, y: number, r: number) => {
      ctx.beginPath();
      for (let i = 0; i < 6; i++) {
        const a = (Math.PI / 3) * i + Math.PI / 6;
        const px = x + r * Math.cos(a);
        const py = y + r * Math.sin(a);
        i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
      }
      ctx.closePath();
    };

    const draw = (t: number) => {
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.clearRect(0, 0, W, H);
      for (const c of cells) {
        const d = Math.hypot(c.x - mouse.x, c.y - mouse.y);
        const target = Math.max(0, 1 - d / 230);
        c.heat += (target - c.heat) * 0.08;
        const idle = 0.028 + 0.02 * Math.sin(t / 2200 + c.phase);
        const a = Math.min(0.5, idle + c.heat * 0.5);
        const bright = c.heat > 0.5;
        const [r, g, b] = bright ? GOLD_BRIGHT : GOLD;
        ctx.strokeStyle = `rgba(${r},${g},${b},${a})`;
        ctx.lineWidth = 0.8;
        hex(c.x, c.y, R - 5 + c.heat * 3);
        ctx.stroke();
      }
    };

    const frame = (t: number) => {
      if (!running) return;
      draw(t);
      raf = requestAnimationFrame(frame);
    };
    const start = () => {
      if (running || reduce) return;
      running = true;
      raf = requestAnimationFrame(frame);
    };
    const stop = () => {
      running = false;
      cancelAnimationFrame(raf);
    };

    build();
    if (reduce) draw(0);

    const ro = new ResizeObserver(() => {
      build();
      if (reduce) draw(0);
    });
    ro.observe(section);

    const io = new IntersectionObserver((es) =>
      es[0]?.isIntersecting ? start() : stop()
    );
    io.observe(section);

    section.addEventListener('pointermove', (e) => {
      const rect = section.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    });
    section.addEventListener('pointerleave', () => {
      mouse.x = -9999;
      mouse.y = -9999;
    });
  }
</script>
