---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { COMPANY } from '../lib/site';
import { fileBaseName, formatDate, toPlainExcerpt } from '../lib/slug';
// 기존 Next 프로젝트 데이터 재사용 (원본 단일 출처)
import { projects } from '../../../src/data/projects';

const featured = projects.filter((p) => p.status === '운영 중').slice(0, 4);

const entries = await getCollection('posts');
const latestPosts = entries
  .map((post) => ({
    slug: post.id,
    title: post.data.title || fileBaseName(post.filePath) || post.id,
    description: post.data.description || toPlainExcerpt(post.body || '', 100),
    date: post.data.date || '',
    dateLabel: formatDate(post.data.date)
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);

const services = [
  {
    title: '웹 · 모바일 제품 개발',
    body: 'Next.js·Astro 웹부터 Flutter·React Native 앱까지, 아이디어를 스토어와 브라우저에 올라가는 제품으로 만듭니다.',
    icon: 'M4 6h16M4 6v12h16V6M9 18v2h6v-2'
  },
  {
    title: 'MVP · 프로토타입',
    body: '검증이 필요한 아이디어를 몇 주 안에 만질 수 있는 형태로. 작게 만들어 빠르게 배우는 걸 돕습니다.',
    icon: 'M13 3 4 14h6l-1 7 9-11h-6l1-7Z'
  },
  {
    title: 'AI · 업무 자동화',
    body: '수집·요약·발행 파이프라인, LLM 에이전트 워크플로 등 반복 업무를 소프트웨어로 대체합니다.',
    icon: 'M12 3v3m0 12v3M3 12h3m12 0h3M7 7l2 2m6 6 2 2m0-10-2 2M9 15l-2 2m8-5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z'
  }
];

const steps = [
  { n: '01', t: '문의 · 상담', d: '만들고 싶은 것과 제약을 듣습니다.' },
  { n: '02', t: '스코핑', d: '범위·일정·비용을 문서로 확정합니다.' },
  { n: '03', t: '설계 · 프로토타입', d: '만질 수 있는 초안으로 방향을 검증합니다.' },
  { n: '04', t: '개발 · 검증', d: '주 단위로 동작하는 결과물을 공유합니다.' },
  { n: '05', t: '출시 · 운영', d: '배포 후에도 지표와 함께 개선을 잇습니다.' }
];
---

<Base
  title="토리스 (Toris Inc.) — 꾸준함이 완성하는 소프트웨어"
  description={COMPANY.description}
  path="/"
>
  <!-- ============================== Hero ============================== -->
  <section class="relative overflow-hidden">
    <canvas
      id="shell-canvas"
      class="pointer-events-none absolute inset-0 h-full w-full"
      aria-hidden="true"></canvas>

    <div
      class="relative mx-auto flex min-h-[calc(100dvh-4rem)] max-w-6xl flex-col items-start justify-center px-5 py-24"
    >
      <p
        class="hero-in inline-flex items-center gap-2 rounded-full border border-teal-200 bg-white/70 px-4 py-1.5 text-xs font-semibold tracking-widest text-teal-800 backdrop-blur"
      >
        <span class="size-1.5 rounded-full bg-amber-500"></span>
        TORIS INC. · SOFTWARE STUDIO
      </p>

      <h1
        class="hero-in mt-7 max-w-3xl text-5xl font-extrabold leading-[1.08] tracking-tight text-ink-900 sm:text-6xl lg:text-7xl"
        style="transition-delay: 90ms"
      >
        꾸준함이<br />
        <span class="text-teal-700">제품을 완성</span>합니다
      </h1>

      <p
        class="hero-in mt-7 max-w-xl text-lg leading-relaxed text-ink-500"
        style="transition-delay: 180ms"
      >
        토리스는 웹·모바일·자동화 제품을 기획부터 출시, 운영까지 직접 만드는
        1인 소프트웨어 스튜디오입니다. 거북이처럼 — 서두르지 않지만, 반드시
        도착합니다.
      </p>

      <div class="hero-in mt-10 flex flex-wrap gap-3" style="transition-delay: 270ms">
        <a
          href="/contact"
          class="inline-flex h-12 items-center gap-2 rounded-full bg-teal-700 px-7 text-[15px] font-semibold text-white shadow-lg shadow-teal-700/20 transition-all hover:-translate-y-0.5 hover:bg-teal-800 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-600 active:translate-y-0"
        >
          프로젝트 문의하기
          <svg viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M5 12h14m-6-6 6 6-6 6"></path>
          </svg>
        </a>
        <a
          href="/projects"
          class="inline-flex h-12 items-center rounded-full border border-ink-300/60 bg-white/70 px-7 text-[15px] font-semibold text-ink-700 backdrop-blur transition-all hover:-translate-y-0.5 hover:border-teal-400 hover:text-teal-800 focus-visible:outline-2 focus-visible:outline-teal-600 active:translate-y-0"
        >
          만든 제품 보기
        </a>
      </div>

      <dl class="hero-in mt-16 grid grid-cols-3 gap-8 sm:gap-14" style="transition-delay: 360ms">
        <div>
          <dt class="text-xs font-medium uppercase tracking-wider text-ink-400">출시·운영 제품</dt>
          <dd class="mt-1 text-3xl font-extrabold tabular-nums text-ink-900">
            <span data-count={String(projects.length)}>0</span>+
          </dd>
        </div>
        <div>
          <dt class="text-xs font-medium uppercase tracking-wider text-ink-400">기술 아티클</dt>
          <dd class="mt-1 text-3xl font-extrabold tabular-nums text-ink-900">
            <span data-count={String(entries.length)}>0</span>
          </dd>
        </div>
        <div>
          <dt class="text-xs font-medium uppercase tracking-wider text-ink-400">다루는 플랫폼</dt>
          <dd class="mt-1 text-3xl font-extrabold tabular-nums text-ink-900">
            <span data-count="4">0</span>
          </dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ============================ Services ============================ -->
  <section class="border-t border-line bg-white">
    <div class="mx-auto max-w-6xl px-5 py-24">
      <div class="reveal max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-teal-700">What we do</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">
          작게 시작해서, 끝까지 만듭니다
        </h2>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {
          services.map((s, i) => (
            <article
              class="reveal group rounded-2xl border border-line bg-paper p-7 transition-all hover:-translate-y-1 hover:border-teal-300 hover:shadow-xl hover:shadow-teal-900/5"
              style={`transition-delay: ${i * 80}ms`}
            >
              <span class="flex size-12 items-center justify-center rounded-xl bg-teal-50 text-teal-700 transition-colors group-hover:bg-teal-700 group-hover:text-white">
                <svg viewBox="0 0 24 24" class="size-6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={s.icon} />
                </svg>
              </span>
              <h3 class="mt-5 text-lg font-bold text-ink-900">{s.title}</h3>
              <p class="mt-2.5 text-[15px] leading-relaxed text-ink-500">{s.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============================ Projects ============================ -->
  <section class="mx-auto max-w-6xl px-5 py-24">
    <div class="reveal flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-teal-700">Products</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">
          직접 만들어 운영 중인 제품
        </h2>
      </div>
      <a
        href="/projects"
        class="text-sm font-semibold text-teal-700 hover:underline focus-visible:outline-2 focus-visible:outline-teal-600"
      >
        전체 보기 →
      </a>
    </div>
    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      {
        featured.map((p, i) => (
          <a
            href={p.github}
            target="_blank"
            rel="noopener noreferrer"
            class="reveal group relative overflow-hidden rounded-2xl border border-line bg-white p-7 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-teal-900/5 focus-visible:outline-2 focus-visible:outline-teal-600"
            style={`transition-delay: ${i * 70}ms`}
          >
            <span
              class="absolute inset-x-0 top-0 h-1 opacity-70"
              style={`background: linear-gradient(90deg, ${p.accent.from}, ${p.accent.to})`}
            />
            <div class="flex items-center justify-between gap-3">
              <h3 class="text-xl font-extrabold text-ink-900">{p.name}</h3>
              <span class="rounded-full bg-teal-50 px-2.5 py-1 text-[11px] font-semibold text-teal-800">
                {p.status}
              </span>
            </div>
            <p class="mt-1 text-sm font-medium text-ink-400">{p.category}</p>
            <p class="mt-3 line-clamp-2 text-[15px] leading-relaxed text-ink-500">
              {p.tagline}
            </p>
            <p class="mt-5 flex flex-wrap gap-1.5">
              {p.tech.slice(0, 4).map((t) => (
                <span class="rounded-md border border-line bg-paper px-2 py-0.5 text-[11px] font-medium text-ink-500">
                  {t}
                </span>
              ))}
            </p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ============================= Process ============================ -->
  <section class="border-y border-line bg-paper-warm">
    <div class="mx-auto max-w-6xl px-5 py-24">
      <div class="reveal max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-teal-700">Process</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">
          다섯 걸음이면 충분합니다
        </h2>
      </div>
      <ol class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
        {
          steps.map((s, i) => (
            <li
              class="reveal rounded-2xl border border-line bg-white p-5"
              style={`transition-delay: ${i * 60}ms`}
            >
              <span class="text-sm font-extrabold tabular-nums text-amber-600">{s.n}</span>
              <h3 class="mt-2 font-bold text-ink-900">{s.t}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-ink-500">{s.d}</p>
            </li>
          ))
        }
      </ol>
      <p class="reveal mt-8">
        <a
          href="/process"
          class="text-sm font-semibold text-teal-700 hover:underline focus-visible:outline-2 focus-visible:outline-teal-600"
        >
          진행 방식 자세히 보기 →
        </a>
      </p>
    </div>
  </section>

  <!-- ============================== Blog ============================== -->
  <section class="mx-auto max-w-6xl px-5 py-24">
    <div class="reveal flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-teal-700">Blog</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">
          만들면서 배운 것들
        </h2>
      </div>
      <a
        href="/blog"
        class="text-sm font-semibold text-teal-700 hover:underline focus-visible:outline-2 focus-visible:outline-teal-600"
      >
        블로그 전체 →
      </a>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {
        latestPosts.map((post, i) => (
          <a
            href={`/posts/${encodeURIComponent(post.slug)}`}
            class="reveal group rounded-2xl border border-line bg-white p-6 transition-all hover:-translate-y-1 hover:border-teal-300 hover:shadow-xl hover:shadow-teal-900/5 focus-visible:outline-2 focus-visible:outline-teal-600"
            style={`transition-delay: ${i * 70}ms`}
          >
            {post.dateLabel && (
              <time datetime={post.date} class="text-xs text-ink-400">
                {post.dateLabel}
              </time>
            )}
            <h3 class="mt-2 line-clamp-2 text-lg font-bold leading-snug text-ink-900 group-hover:text-teal-800">
              {post.title}
            </h3>
            <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-ink-500">
              {post.description}
            </p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- =============================== CTA =============================== -->
  <section class="mx-auto max-w-6xl px-5 pb-28">
    <div
      class="reveal relative overflow-hidden rounded-3xl bg-teal-800 px-8 py-16 text-center sm:px-16"
    >
      <div
        class="pointer-events-none absolute inset-0 opacity-15"
        style="background-image: radial-gradient(circle at 20% 20%, #fbbf24, transparent 40%), radial-gradient(circle at 85% 80%, #3cbcae, transparent 45%)"
        aria-hidden="true"
      >
      </div>
      <h2 class="relative text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        만들고 싶은 것이 있나요?
      </h2>
      <p class="relative mx-auto mt-4 max-w-xl text-teal-100">
        아이디어 단계여도 좋습니다. 무엇을, 왜 만들고 싶은지 들려주세요 —
        하루 안에 답장드립니다.
      </p>
      <a
        href="/contact"
        class="relative mt-9 inline-flex h-12 items-center gap-2 rounded-full bg-amber-500 px-8 text-[15px] font-bold text-ink-900 transition-all hover:-translate-y-0.5 hover:bg-amber-400 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white active:translate-y-0"
      >
        지금 문의하기
      </a>
    </div>
  </section>
</Base>

<style>
  /* 히어로 진입 모션 */
  .hero-in {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  :global(body.hero-ready) .hero-in {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-in {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  // ---------- 히어로 진입 ----------
  requestAnimationFrame(() => document.body.classList.add('hero-ready'));

  // ---------- 숫자 카운트업 ----------
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  document.querySelectorAll<HTMLElement>('[data-count]').forEach((el) => {
    const target = Number(el.dataset.count || '0');
    if (reduce) {
      el.textContent = String(target);
      return;
    }
    const t0 = performance.now();
    const dur = 1200;
    const tick = (now: number) => {
      const p = Math.min(1, (now - t0) / dur);
      el.textContent = String(Math.round(target * (1 - Math.pow(1 - p, 3))));
      if (p < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  });

  // ---------- 인터랙티브 거북이 등껍질(육각) 캔버스 ----------
  const canvas = document.getElementById('shell-canvas') as HTMLCanvasElement | null;
  const section = canvas?.parentElement;
  const ctx = canvas?.getContext('2d');
  if (canvas && ctx && section) {
    const TEAL = [23, 163, 148];
    const AMBER = [245, 158, 11];
    let W = 0;
    let H = 0;
    let dpr = 1;
    let raf = 0;
    let running = false;
    type Cell = { x: number; y: number; heat: number; phase: number };
    let cells: Cell[] = [];
    const mouse = { x: -9999, y: -9999 };
    const R = 34; // 육각 반지름

    const build = () => {
      const rect = section.getBoundingClientRect();
      W = rect.width;
      H = rect.height;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.round(W * dpr);
      canvas.height = Math.round(H * dpr);
      cells = [];
      const dx = R * 1.732;
      const dy = R * 1.5;
      for (let row = 0; row * dy < H + R; row++) {
        for (let col = 0; col * dx < W + R; col++) {
          cells.push({
            x: col * dx + (row % 2 ? dx / 2 : 0),
            y: row * dy,
            heat: 0,
            phase: Math.random() * Math.PI * 2
          });
        }
      }
    };

    const hex = (x: number, y: number, r: number) => {
      ctx.beginPath();
      for (let i = 0; i < 6; i++) {
        const a = (Math.PI / 3) * i + Math.PI / 6;
        const px = x + r * Math.cos(a);
        const py = y + r * Math.sin(a);
        i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
      }
      ctx.closePath();
    };

    const draw = (t: number) => {
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.clearRect(0, 0, W, H);
      for (const c of cells) {
        const d = Math.hypot(c.x - mouse.x, c.y - mouse.y);
        const target = Math.max(0, 1 - d / 190);
        c.heat += (target - c.heat) * 0.09;
        const idle = 0.05 + 0.03 * Math.sin(t / 1600 + c.phase);
        const a = Math.min(0.85, idle + c.heat * 0.8);
        const warm = c.heat > 0.55;
        const [r, g, b] = warm ? AMBER : TEAL;
        ctx.strokeStyle = `rgba(${r},${g},${b},${a * 0.55})`;
        ctx.lineWidth = 1;
        hex(c.x, c.y, R - 4 + c.heat * 3);
        ctx.stroke();
        if (c.heat > 0.04) {
          ctx.fillStyle = `rgba(${r},${g},${b},${c.heat * 0.1})`;
          ctx.fill();
        }
      }
    };

    const frame = (t: number) => {
      if (!running) return;
      draw(t);
      raf = requestAnimationFrame(frame);
    };
    const start = () => {
      if (running || reduce) return;
      running = true;
      raf = requestAnimationFrame(frame);
    };
    const stop = () => {
      running = false;
      cancelAnimationFrame(raf);
    };

    build();
    if (reduce) draw(0);

    const ro = new ResizeObserver(() => {
      build();
      if (reduce) draw(0);
    });
    ro.observe(section);

    const io = new IntersectionObserver((es) =>
      es[0]?.isIntersecting ? start() : stop()
    );
    io.observe(section);

    section.addEventListener('pointermove', (e) => {
      const rect = section.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    });
    section.addEventListener('pointerleave', () => {
      mouse.x = -9999;
      mouse.y = -9999;
    });
  }
</script>
