---
import Base from '../layouts/Base.astro';
import CardFX from '../components/CardFX.astro';
import { SITE_URL, absoluteUrl } from '../lib/site';
// 기존 Next 프로젝트 데이터 재사용 (원본 단일 출처)
import { projects } from '../../../src/data/projects';

const live = projects.filter((p) => p.status === '운영 중');
const building = projects.filter((p) => p.status === '개발 중');
const shipped = projects.filter((p) => p.status === '출시');

const groups = [
  { label: '운영 중', items: live, dot: 'bg-live', text: 'text-live', wide: true },
  { label: '개발 중', items: building, dot: 'bg-mint', text: 'text-mint', wide: false },
  { label: '출시', items: shipped, dot: 'bg-sand', text: 'text-muted', wide: false }
].filter((g) => g.items.length > 0);

// 서비스 링크(웹사이트·스토어·릴리스 다운로드)만 클릭 허용.
// GitHub 리포/프로필 루트로만 가는 항목은 카드 링크를 제거한다.
const isServiceLink = (url: string) =>
  !url.startsWith('https://github.com/') || /\/releases\/?$/.test(url);

// 제품 구조화 데이터 — 운영 중 제품을 SoftwareApplication ItemList로 노출
const osOf = (platform: string) => {
  const s = platform.toLowerCase();
  if (/desktop|macos|windows|linux/.test(s)) return 'macOS, Windows, Linux';
  if (/mobile|ios|android/.test(s)) return 'iOS, Android';
  if (/npm|library|node/.test(s)) return 'Node.js';
  return 'Web';
};
const productsJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: '토리스가 운영 중인 제품',
  itemListElement: live.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'SoftwareApplication',
      name: p.name,
      description: p.tagline,
      applicationCategory: p.category,
      operatingSystem: osOf(p.platform),
      ...(isServiceLink(p.github) ? { url: p.github } : {}),
      author: { '@type': 'Organization', name: '토리스', url: SITE_URL },
      image: absoluteUrl('/og-default.png')
    }
  }))
});
---

<Base
  title="프로젝트 | 토리스"
  description="토리스가 직접 기획·개발·운영하는 제품들 — 웹, 모바일, 자동화까지 만든 것들을 모았습니다."
  path="/projects"
  pageType="CollectionPage"
  breadcrumbs={[{ name: '홈', url: '/' }, { name: '프로젝트' }]}
>
  <script type="application/ld+json" set:html={productsJsonLd} />
  <!-- ============================== Hero ============================== -->
  <section class="mx-auto max-w-6xl px-5 pb-6 pt-20 sm:pt-28">
    <div class="reveal flex items-center gap-4">
      <span class="rule-accent w-16" aria-hidden="true"></span>
      <p class="text-xs font-semibold tracking-[0.35em] text-mint">PRODUCTS</p>
    </div>
    <h1
      class="reveal font-display mt-6 text-4xl text-ink sm:text-5xl"
      style="transition-delay: 60ms"
    >
      만든 것들
    </h1>
    <p
      class="reveal mt-5 max-w-xl break-keep text-lg leading-relaxed text-ink-dim"
      style="transition-delay: 120ms"
    >
      직접 기획하고, 개발하고, 운영하는 제품들입니다. 작게 시작해서 꾸준히
      고치며 키워갑니다.
    </p>
  </section>

  <!-- ============================ 상태별 그룹 ============================ -->
  {
    groups.map((group) => (
      <section
        class="mx-auto max-w-6xl px-5 py-14"
        aria-label={`${group.label} 프로젝트`}
      >
        <h2 class="reveal font-display flex items-center gap-3 text-2xl text-ink">
          <span
            class:list={['size-1.5 rounded-full', group.dot]}
            aria-hidden="true"
          />
          {group.label}
          <span class="text-sm font-normal tracking-wider text-muted">
            {group.items.length}
          </span>
        </h2>
        <div
          class:list={[
            'mt-8 grid gap-4',
            group.wide ? 'sm:grid-cols-2' : 'sm:grid-cols-2 lg:grid-cols-3'
          ]}
        >
          {group.items.map((p, i) => { const linked = isServiceLink(p.github); const Tag = linked ? 'a' : 'div'; return (
            <Tag
              href={linked ? p.github : undefined}
              target={linked ? '_blank' : undefined}
              rel={linked ? 'noopener noreferrer' : undefined}
              class="card-3d reveal group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-card p-7 transition-[border-color] duration-300 hover:border-mint-deep focus-visible:outline-2 focus-visible:outline-mint"
              style={`transition-delay: ${i * 60}ms`}
            >
              <span class="card-glare" aria-hidden="true" />
              <p class="text-[11px] font-medium uppercase tracking-[0.3em] text-muted">
                {p.category}
              </p>
              <h3
                class:list={[
                  'font-display mt-3 text-ink',
                  group.wide ? 'text-2xl sm:text-3xl' : 'text-2xl'
                ]}
              >
                {p.name}
              </h3>
              <p class="mt-3 break-keep text-sm leading-relaxed text-ink-dim">
                {p.tagline}
              </p>
              <p class="mt-4 text-xs tracking-wide text-muted">
                {p.tech.slice(0, 4).join(' · ')}
              </p>
              <span class="mt-auto flex items-center justify-between gap-3 pt-7">
                <span
                  class:list={[
                    'flex items-center gap-2 text-[11px] tracking-wider',
                    group.text
                  ]}
                >
                  <span
                    class:list={['size-1.5 rounded-full', group.dot]}
                    aria-hidden="true"
                  />
                  {p.status}
                </span>
                {linked && (
                  <span class="flex items-center gap-1.5 text-[13px] font-medium text-muted transition-colors duration-300 group-hover:text-mint">
                    서비스 열기
                    <svg
                      viewBox="0 0 24 24"
                      class="size-3.5 transition-transform duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M7 17 17 7M9 7h8v8" />
                    </svg>
                  </span>
                )}
              </span>
              <span
                class="absolute -bottom-px left-0 h-px w-0 bg-mint transition-all duration-500 group-hover:w-full"
                aria-hidden="true"
              />
            </Tag>
          ); })}
        </div>
      </section>
    ))
  }

  <!-- =============================== CTA =============================== -->
  <section class="mx-auto max-w-6xl px-5 py-20">
    <div class="reveal relative overflow-hidden rounded-2xl border border-line bg-card px-8 py-14 text-center">
      <span class="rule-accent absolute inset-x-0 top-0" aria-hidden="true"></span>
      <h2 class="font-display text-2xl text-ink sm:text-3xl">
        이런 제품, 함께 만들어볼까요?
      </h2>
      <p class="mx-auto mt-3 max-w-xl break-keep text-ink-dim">
        아이디어 단계여도 좋습니다. 만들고 싶은 것을 들려주세요.
      </p>
      <a
        href="/contact"
        class="mt-8 inline-flex h-12 items-center gap-2 border border-mint bg-mint rounded-lg px-8 text-[15px] font-semibold text-ink transition-all duration-300 hover:-translate-y-0.5 hover:bg-mint-bright hover:shadow-[0_8px_32px_-8px_color-mix(in_srgb,var(--color-mint)_45%,transparent)] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-mint active:translate-y-0"
      >
        프로젝트 문의하기
        <svg
          viewBox="0 0 24 24"
          class="size-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M5 12h14m-6-6 6 6-6 6"></path>
        </svg>
      </a>
    </div>
  </section>

  <CardFX />
</Base>
