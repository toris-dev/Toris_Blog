---
import Base from '../layouts/Base.astro';
// 기존 Next 프로젝트 데이터 재사용 (원본 단일 출처)
import { projects } from '../../../src/data/projects';

const live = projects.filter((p) => p.status === '운영 중');
const building = projects.filter((p) => p.status === '개발 중');
const shipped = projects.filter((p) => p.status === '출시');

const compactGroups = [
  { label: '개발 중', items: building, badge: 'bg-amber-50 text-amber-800' },
  { label: '출시', items: shipped, badge: 'bg-paper text-ink-600' }
].filter((g) => g.items.length > 0);
---

<Base
  title="프로젝트 | 토리스"
  description="토리스가 직접 기획·개발·운영하는 제품들 — 웹, 모바일, 자동화까지 만든 것들을 모았습니다."
  path="/projects"
>
  <!-- ============================== Hero ============================== -->
  <section class="mx-auto max-w-6xl px-5 pb-6 pt-20 sm:pt-28">
    <p class="reveal text-sm font-semibold uppercase tracking-[0.2em] text-teal-700">
      Products
    </p>
    <h1
      class="reveal mt-3 text-4xl font-extrabold tracking-tight text-ink-900 sm:text-5xl"
      style="transition-delay: 60ms"
    >
      만든 것들
    </h1>
    <p
      class="reveal mt-5 max-w-xl text-lg leading-relaxed text-ink-500"
      style="transition-delay: 120ms"
    >
      직접 기획하고, 개발하고, 운영하는 제품들입니다. 작게 시작해서 꾸준히
      고치며 키워갑니다.
    </p>
  </section>

  <!-- ============================ 운영 중 ============================ -->
  {
    live.length > 0 && (
      <section class="mx-auto max-w-6xl px-5 py-14" aria-labelledby="live-heading">
        <h2
          id="live-heading"
          class="reveal flex items-center gap-2.5 text-2xl font-extrabold tracking-tight text-ink-900"
        >
          <span class="size-2 rounded-full bg-teal-600" aria-hidden="true" />
          운영 중
        </h2>
        <div class="mt-8 grid gap-6 sm:grid-cols-2">
          {live.map((p, i) => (
            <a
              href={p.github}
              target="_blank"
              rel="noopener noreferrer"
              class="reveal group relative overflow-hidden rounded-2xl border border-line bg-white p-7 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-teal-900/5 focus-visible:outline-2 focus-visible:outline-teal-600"
              style={`transition-delay: ${i * 70}ms`}
            >
              <span
                class="absolute inset-x-0 top-0 h-1 opacity-70"
                style={`background-image: linear-gradient(90deg, ${p.accent.from}, ${p.accent.to})`}
              />
              <div class="flex items-center justify-between gap-3">
                <h3 class="text-xl font-extrabold text-ink-900 group-hover:text-teal-800">
                  {p.name}
                </h3>
                <span class="shrink-0 rounded-full bg-teal-50 px-2.5 py-1 text-[11px] font-semibold text-teal-800">
                  {p.status}
                </span>
              </div>
              <p class="mt-1 text-sm font-medium text-ink-400">{p.category}</p>
              <p class="mt-3 line-clamp-2 text-[15px] leading-relaxed text-ink-500">
                {p.tagline}
              </p>
              <p class="mt-5 flex flex-wrap gap-1.5">
                {p.tech.slice(0, 4).map((t) => (
                  <span class="rounded-md border border-line bg-paper px-2 py-0.5 text-[11px] font-medium text-ink-500">
                    {t}
                  </span>
                ))}
              </p>
            </a>
          ))}
        </div>
      </section>
    )
  }

  <!-- ======================= 개발 중 · 출시 ======================= -->
  {
    compactGroups.map((group) => (
      <section
        class="mx-auto max-w-6xl px-5 py-14"
        aria-label={`${group.label} 프로젝트`}
      >
        <h2 class="reveal flex items-center gap-2.5 text-2xl font-extrabold tracking-tight text-ink-900">
          <span
            class:list={[
              'size-2 rounded-full',
              group.label === '개발 중' ? 'bg-amber-500' : 'bg-ink-400'
            ]}
            aria-hidden="true"
          />
          {group.label}
        </h2>
        <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {group.items.map((p, i) => (
            <a
              href={p.github}
              target="_blank"
              rel="noopener noreferrer"
              class="reveal group relative overflow-hidden rounded-2xl border border-line bg-white p-6 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-teal-900/5 focus-visible:outline-2 focus-visible:outline-teal-600"
              style={`transition-delay: ${i * 60}ms`}
            >
              <span
                class="absolute inset-x-0 top-0 h-1 opacity-70"
                style={`background-image: linear-gradient(90deg, ${p.accent.from}, ${p.accent.to})`}
              />
              <div class="flex items-center justify-between gap-3">
                <h3 class="text-lg font-extrabold text-ink-900 group-hover:text-teal-800">
                  {p.name}
                </h3>
                <span
                  class:list={[
                    'shrink-0 rounded-full px-2.5 py-1 text-[11px] font-semibold',
                    group.badge
                  ]}
                >
                  {p.status}
                </span>
              </div>
              <p class="mt-1 text-sm font-medium text-ink-400">{p.category}</p>
              <p class="mt-2.5 line-clamp-2 text-sm leading-relaxed text-ink-500">
                {p.tagline}
              </p>
              <p class="mt-4 flex flex-wrap gap-1.5">
                {p.tech.slice(0, 4).map((t) => (
                  <span class="rounded-md border border-line bg-paper px-2 py-0.5 text-[11px] font-medium text-ink-500">
                    {t}
                  </span>
                ))}
              </p>
            </a>
          ))}
        </div>
      </section>
    ))
  }

  <!-- =============================== CTA =============================== -->
  <section class="mx-auto max-w-6xl px-5 py-20">
    <div class="reveal rounded-3xl border border-line bg-paper-warm px-8 py-12 text-center">
      <h2 class="text-2xl font-extrabold tracking-tight text-ink-900 sm:text-3xl">
        이런 제품, 함께 만들어볼까요?
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-ink-500">
        아이디어 단계여도 좋습니다. 만들고 싶은 것을 들려주세요.
      </p>
      <a
        href="/contact"
        class="mt-7 inline-flex h-12 items-center gap-2 rounded-full bg-teal-700 px-7 text-[15px] font-semibold text-white shadow-lg shadow-teal-700/20 transition-all hover:-translate-y-0.5 hover:bg-teal-800 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-600 active:translate-y-0"
      >
        프로젝트 문의하기
        <svg
          viewBox="0 0 24 24"
          class="size-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M5 12h14m-6-6 6 6-6 6"></path>
        </svg>
      </a>
    </div>
  </section>
</Base>
