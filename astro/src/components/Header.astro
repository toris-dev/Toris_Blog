---
import { NAV } from '../lib/site';
const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? current === '/' : current.startsWith(href);
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-line/60 bg-paper/85 backdrop-blur-md"
>
  <nav
    class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5"
    aria-label="주 메뉴"
  >
    <a
      href="/"
      class="flex items-center gap-2.5 rounded-lg focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-teal-600"
    >
      <!-- 거북이 등껍질 육각 모노그램 -->
      <svg viewBox="0 0 32 32" class="size-8" aria-hidden="true">
        <path
          d="M16 3 27 9.5v13L16 29 5 22.5v-13L16 3Z"
          fill="none"
          stroke="#0f6a62"
          stroke-width="2.4"
          stroke-linejoin="round"></path>
        <path
          d="M16 10.5 21 13.5v6l-5 3-5-3v-6l5-3Z"
          fill="#17a394"
          opacity="0.9"></path>
      </svg>
      <span class="text-lg font-extrabold tracking-tight text-ink-900">
        토리스 <span class="font-semibold text-teal-700">TORIS</span>
      </span>
    </a>

    <div class="hidden items-center gap-1 md:flex">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'rounded-full px-4 py-2 text-[15px] font-medium transition-colors focus-visible:outline-2 focus-visible:outline-teal-600',
              isActive(item.href)
                ? 'bg-teal-700 text-white'
                : 'text-ink-700 hover:bg-teal-50 hover:text-teal-800'
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <button
      id="menu-toggle"
      type="button"
      class="flex size-11 items-center justify-center rounded-lg text-ink-700 focus-visible:outline-2 focus-visible:outline-teal-600 md:hidden"
      aria-label="메뉴 열기"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        viewBox="0 0 24 24"
        class="size-6"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <path d="M4 7h16M4 12h16M4 17h16"></path>
      </svg>
    </button>
  </nav>

  <div
    id="mobile-menu"
    class="hidden border-t border-line/60 bg-paper px-5 pb-4 pt-2 md:hidden"
  >
    {
      NAV.map((item) => (
        <a
          href={item.href}
          class="block rounded-lg px-3 py-3 text-[15px] font-medium text-ink-700 hover:bg-teal-50 hover:text-teal-800 focus-visible:outline-2 focus-visible:outline-teal-600"
        >
          {item.label}
        </a>
      ))
    }
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? '메뉴 닫기' : '메뉴 열기');
  });
</script>
