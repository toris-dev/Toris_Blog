---
import LogoMark from './LogoMark.astro';
import { NAV } from '../lib/site';
const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? current === '/' : current.startsWith(href);
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-line/70 bg-night/85 backdrop-blur-md"
>
  <nav
    class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5"
    aria-label="주 메뉴"
  >
    <a
      href="/"
      class="group flex items-center gap-3 rounded-lg focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-gold"
    >
      <LogoMark class="size-8 transition-transform duration-300 group-hover:rotate-[12deg]" />
      <span class="flex items-baseline gap-2">
        <span class="font-display text-xl text-ivory">토리스</span>
        <span class="text-[11px] font-semibold tracking-[0.3em] text-gold">TORIS</span>
      </span>
    </a>

    <div class="hidden items-center gap-1 md:flex">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'relative rounded-md px-4 py-2 text-[15px] transition-colors focus-visible:outline-2 focus-visible:outline-gold',
              isActive(item.href)
                ? 'font-semibold text-gold'
                : 'text-ivory-dim hover:text-ivory'
            ]}
          >
            {item.label}
            {isActive(item.href) && (
              <span
                class="absolute inset-x-4 -bottom-px h-px bg-gold"
                aria-hidden="true"
              />
            )}
          </a>
        ))
      }
    </div>

    <button
      id="menu-toggle"
      type="button"
      class="flex size-11 items-center justify-center rounded-lg text-ivory-dim hover:text-ivory focus-visible:outline-2 focus-visible:outline-gold md:hidden"
      aria-label="메뉴 열기"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        viewBox="0 0 24 24"
        class="size-6"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <path d="M4 7h16M4 12h16M4 17h16"></path>
      </svg>
    </button>
  </nav>

  <div
    id="mobile-menu"
    class="hidden border-t border-line/70 bg-night px-5 pb-5 pt-2 md:hidden"
  >
    {
      NAV.map((item) => (
        <a
          href={item.href}
          class="block rounded-lg px-3 py-3 text-[15px] text-ivory-dim hover:bg-coal hover:text-ivory focus-visible:outline-2 focus-visible:outline-gold"
        >
          {item.label}
        </a>
      ))
    }
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? '메뉴 닫기' : '메뉴 열기');
  });
</script>
