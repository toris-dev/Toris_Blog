---
/**
 * 페이지 공통 SEO — 기존 Next generateMetadata의 title/description/
 * canonical/OG/Twitter/JSON-LD 출력을 보존한다. (요구사항)
 */
import { COMPANY, SITE_URL, absoluteUrl } from '../lib/site';

interface Article {
  headline?: string;
  publishedAt?: string;
  modifiedAt?: string;
  tags?: string[];
  category?: string;
  wordCount?: number;
}

interface Crumb {
  name: string;
  url?: string;
}

interface Props {
  title: string;
  description: string;
  path: string; // '/', '/posts/slug' 등 — canonical 계산에 사용
  ogType?: 'website' | 'article';
  image?: string;
  article?: Article;
  /** WebPage 하위 타입 (AboutPage·ContactPage 등) */
  pageType?: 'WebPage' | 'AboutPage' | 'ContactPage' | 'CollectionPage';
  /** 홈부터의 경로 — BreadcrumbList 생성 */
  breadcrumbs?: Crumb[];
  noindex?: boolean;
}

const {
  title,
  description,
  path,
  ogType = 'website',
  image = '/og-default.png',
  article,
  pageType = 'WebPage',
  breadcrumbs,
  noindex = false
} = Astro.props;

const canonical = absoluteUrl(path);
const ogImage = image.startsWith('http') ? image : absoluteUrl(image);

/* ---------- JSON-LD @graph (Next의 buildGlobalGraph/buildArticleGraph 포팅) ---------- */
const ids = {
  person: `${SITE_URL}/#person`,
  organization: `${SITE_URL}/#organization`,
  website: `${SITE_URL}/#website`
};

const personNode = {
  '@type': 'Person',
  '@id': ids.person,
  alternateName: ['toris-dev', 'Toris-dev'],
  name: '토리스',
  alternateName: 'Toris',
  url: SITE_URL,
  image: absoluteUrl('/logo.svg'),
  jobTitle: 'Founder · Full Stack Developer',
  worksFor: { '@id': ids.organization },
  knowsAbout: ['Full Stack Development', 'Next.js', 'Astro', 'Flutter', 'AI Coding Agents'],
  sameAs: [
    'https://www.linkedin.com/in/joohwan-yu',
    'https://x.com/TorisDev'
  ]
};

const organizationNode = {
  '@type': 'Organization',
  '@id': ids.organization,
  name: COMPANY.nameKo,
  alternateName: ['Toris', 'toris', '토리스', 'toris-dev', 'Toris-dev', 'toris.kr'],
  legalName: `${COMPANY.nameKo}(${COMPANY.nameEn})`,
  disambiguatingDescription:
    '웹·모바일·AI 자동화 제품을 기획부터 출시·운영까지 만드는 대한민국 서울의 소프트웨어 개발 스튜디오. 동명의 음악 그룹이나 타 업종 법인과는 무관하다.',
  slogan: '서두르지 않되, 반드시 출시합니다',
  areaServed: 'KR',
  url: SITE_URL,
  logo: {
    '@type': 'ImageObject',
    url: absoluteUrl('/og-default.png'),
    width: 1200,
    height: 630
  },
  founder: { '@id': ids.person },
  taxID: COMPANY.bizNumber,
  email: COMPANY.email,
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    email: COMPANY.email,
    availableLanguage: ['ko', 'en']
  },
  knowsAbout: ['웹 개발', '모바일 앱 개발', '업무 자동화', 'LLM 워크플로'],
  sameAs: [
    'https://www.linkedin.com/in/joohwan-yu',
    'https://x.com/TorisDev'
  ]
};

const websiteNode = {
  '@type': 'WebSite',
  '@id': ids.website,
  url: SITE_URL,
  name: COMPANY.nameKo,
  alternateName: [COMPANY.nameEn, 'toris.kr'],
  description: COMPANY.description,
  inLanguage: 'ko-KR',
  publisher: { '@id': ids.organization }
};

const graph: Record<string, unknown>[] = [
  personNode,
  organizationNode,
  websiteNode,
  {
    '@type': pageType,
    '@id': `${canonical}#webpage`,
    url: canonical,
    name: title,
    description,
    isPartOf: { '@id': ids.website },
    inLanguage: 'ko-KR',
    ...(breadcrumbs?.length
      ? { breadcrumb: { '@id': `${canonical}#breadcrumb` } }
      : {})
  }
];

if (breadcrumbs?.length) {
  graph.push({
    '@type': 'BreadcrumbList',
    '@id': `${canonical}#breadcrumb`,
    itemListElement: breadcrumbs.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: c.name,
      ...(c.url ? { item: absoluteUrl(c.url) } : {})
    }))
  });
}

if (article) {
  graph.push({
    '@type': 'BlogPosting',
    '@id': `${canonical}#article`,
    headline: article.headline ?? title,
    description,
    image: ogImage,
    datePublished: article.publishedAt,
    dateModified: article.modifiedAt ?? article.publishedAt,
    author: { '@id': ids.person },
    publisher: { '@id': ids.organization },
    mainEntityOfPage: { '@id': `${canonical}#webpage` },
    url: canonical,
    inLanguage: 'ko-KR',
    license: 'https://creativecommons.org/licenses/by/4.0/',
    ...(article.tags?.length ? { keywords: article.tags.join(', ') } : {}),
    ...(article.category ? { articleSection: article.category } : {}),
    ...(article.wordCount ? { wordCount: article.wordCount } : {}),
    isAccessibleForFree: true,
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['h1', 'article .prose-post > p:first-of-type']
    }
  });
}

const jsonLd = JSON.stringify({ '@context': 'https://schema.org', '@graph': graph });
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<meta property="og:type" content={ogType} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={`${COMPANY.nameKo} (${COMPANY.nameEn})`} />
<meta property="og:locale" content="ko_KR" />
<meta property="og:image" content={ogImage} />
{
  article?.publishedAt && (
    <meta property="article:published_time" content={article.publishedAt} />
  )
}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:creator" content="@toris_dev" />

<script type="application/ld+json" set:html={jsonLd} />
