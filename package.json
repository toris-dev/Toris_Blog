{
  "name": "toris",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "verify": "node ../scripts/verify-migration.mjs",
    "deploy": "astro build && wrangler deploy && node scripts/indexnow-ping.mjs",
    "deploy:toris": "pnpm run deploy",
    "deploy:builder": "pnpm --filter @builderstep/web run deploy",
    "deploy:field": "pnpm --filter @fieldstep/web run deploy && pnpm --filter @fieldstep/server run deploy",
    "deploy:all": "pnpm run deploy:toris && pnpm run deploy:builder",
    "builder:dev": "pnpm --filter @builderstep/web run dev",
    "builder:typecheck": "pnpm --filter \"@builderstep/*\" run typecheck",
    "builder:test": "pnpm --filter \"@builderstep/*\" run --if-present test",
    "field:dev": "pnpm --filter @fieldstep/web run dev",
    "field:typecheck": "pnpm --filter \"@fieldstep/*\" run typecheck",
    "field:test": "pnpm --filter \"@fieldstep/*\" run --if-present test"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.0",
    "@astrojs/react": "^4.3.0",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.4.0",
    "astro": "^5.12.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.0",
    "typescript": "5.3",
    "wrangler": "^4.26.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.17",
      "@types/react-dom": "19.2.3"
    }
  }
}
