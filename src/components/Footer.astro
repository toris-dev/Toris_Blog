---
import LogoMark from './LogoMark.astro';
import { COMPANY } from '../lib/site';
const year = new Date().getFullYear();
---

<footer class="border-t border-line bg-card">
  <div class="mx-auto max-w-6xl px-5 py-16">
    <div class="flex flex-col gap-12 md:flex-row md:justify-between">
      <div class="max-w-sm">
        <div class="flex items-center gap-3">
          <LogoMark class="size-9" />
          <span class="flex items-baseline gap-2">
            <span class="font-display text-xl text-ink">토리스</span>
            <span class="text-[11px] font-semibold tracking-[0.3em] text-brand">TORIS</span>
          </span>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-muted">
          {COMPANY.description}
        </p>
        <div class="mt-6 flex gap-2">
          <a
            href={`mailto:${COMPANY.email}`}
            aria-label="이메일"
            class="flex size-11 items-center justify-center rounded-lg border border-line text-muted transition-colors hover:border-brand-deep hover:text-brand focus-visible:outline-2 focus-visible:outline-brand"
          >
            <svg
              viewBox="0 0 24 24"
              class="size-5"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              aria-hidden="true"
            >
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="m3 7 9 6 9-6"></path>
            </svg>
          </a>
        </div>
      </div>

      <nav aria-label="푸터 메뉴" class="flex gap-14 sm:gap-20">
        <div>
          <p class="font-mono text-[10px] tracking-[0.22em] text-muted">COMPANY</p>
          <ul class="mt-4 space-y-2.5">
            {
              [
                { href: '/about', label: '회사 소개' },
                { href: '/process', label: '진행 방식' },
                { href: '/contact', label: '문의하기' }
              ].map((item) => (
                <li>
                  <a href={item.href} class="text-sm text-ink-dim transition-colors hover:text-brand-deep focus-visible:outline-2 focus-visible:outline-brand-deep">
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <p class="font-mono text-[10px] tracking-[0.22em] text-muted">WORK & WRITING</p>
          <ul class="mt-4 space-y-2.5">
            {
              [
                { href: '/projects', label: '프로젝트' },
                { href: '/blog', label: '블로그' },
                { href: '/posts', label: '전체 글' }
              ].map((item) => (
                <li>
                  <a href={item.href} class="text-sm text-ink-dim transition-colors hover:text-brand-deep focus-visible:outline-2 focus-visible:outline-brand-deep">
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <p class="font-mono text-[10px] tracking-[0.22em] text-muted">SOCIAL</p>
          <ul class="mt-4 space-y-2.5">
            {
              [
                { href: 'https://www.instagram.com/toris.kr', label: 'Instagram' },
                { href: 'https://github.com/torisKR', label: 'GitHub' },
                { href: 'https://www.linkedin.com/in/toriskorea/', label: 'LinkedIn' },
                { href: 'https://www.threads.com/@toris.kr', label: 'Threads' },
                {
                  href: 'https://play.google.com/store/apps/dev?id=6912640494861955983',
                  label: 'Google Play'
                }
              ].map((item) => (
                <li>
                  <a
                    href={item.href}
                    target="_blank"
                    rel="me noopener"
                    class="text-sm text-ink-dim transition-colors hover:text-brand-deep focus-visible:outline-2 focus-visible:outline-brand-deep"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </nav>
    </div>

    <div class="rule-accent mt-12"></div>

    <!-- 사업자 정보 -->
    <div class="mt-6 text-xs leading-relaxed text-muted/80">
      <p>
        상호: {COMPANY.nameKo}({COMPANY.nameEn}) · 대표: {COMPANY.ceo} ·
        사업자등록번호: {COMPANY.bizNumber}
      </p>
      <p class="mt-1">
        문의: <a href={`mailto:${COMPANY.email}`} class="underline underline-offset-2 hover:text-brand">{COMPANY.email}</a>
        <span class="mx-2" aria-hidden="true">·</span>
        <a href="/privacy" class="underline underline-offset-2 hover:text-brand">개인정보처리방침</a>
        <span class="mx-2" aria-hidden="true">·</span>
        <a href="/terms" class="underline underline-offset-2 hover:text-brand">이용약관</a>
      </p>
      <p class="mt-4">© {year} {COMPANY.nameEn} All rights reserved.</p>
    </div>
  </div>
</footer>
