---
/**
 * 토리스 심볼 마크 — 공식 로고(투명 배경 PNG).
 * 교체 지점: public/logo-symbol.png 파일만 바꾸면 헤더·푸터·히어로에 일괄 반영된다.
 * 워드마크가 포함된 전체 로고는 public/logo-full.png.
 */
interface Props {
  class?: string;
  /** 헤더처럼 즉시 보여야 하는 위치는 eager, 그 외는 lazy */
  loading?: 'eager' | 'lazy';
}
const { class: className = 'size-8', loading = 'eager' } = Astro.props;
---

<span class:list={['logo-chip', className]} aria-hidden="true">
  <img
    src="/logo-symbol.png"
    width="430"
    height="374"
    alt=""
    loading={loading}
    decoding="async"
  />
</span>
