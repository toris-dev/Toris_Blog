---
import LogoMark from './LogoMark.astro';
import { NAV, COMPANY } from '../lib/site';
const current = Astro.url.pathname;
const isEn = current === '/en' || current.startsWith('/en/');
const isActive = (href: string) =>
  href === '/' ? current === '/' : current.startsWith(href);
---

<header
  id="site-header"
  class="glass fixed inset-x-0 top-0 z-50 border-x-0 border-t-0 transition-shadow duration-300"
>
  <nav
    class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 transition-[height] duration-300"
    aria-label="주 메뉴"
  >
    <a
      href={isEn ? '/en' : '/'}
      class="group flex items-center gap-3 rounded-lg focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand"
    >
      <LogoMark class="size-8 transition-transform duration-300 group-hover:rotate-[12deg]" />
      <span class="font-display text-xl text-ink">{isEn ? COMPANY.nameEn : COMPANY.nameKo}</span>
    </a>

    <div class="hidden items-center gap-1 md:flex">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'relative rounded-md px-4 py-2 text-[15px] transition-colors focus-visible:outline-2 focus-visible:outline-brand',
              isActive(item.href)
                ? 'font-semibold text-brand'
                : 'text-ink-dim hover:text-ink'
            ]}
          >
            {item.label}
            {isActive(item.href) && (
              <span
                class="absolute inset-x-4 -bottom-px h-px bg-brand"
                aria-hidden="true"
              />
            )}
          </a>
        ))
      }
    </div>

    <button
      id="menu-toggle"
      type="button"
      class="flex size-11 items-center justify-center rounded-lg text-ink-dim hover:text-ink focus-visible:outline-2 focus-visible:outline-brand md:hidden"
      aria-label="메뉴 열기"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        viewBox="0 0 24 24"
        class="size-6"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <path d="M4 7h16M4 12h16M4 17h16"></path>
      </svg>
    </button>
  </nav>

  <div
    id="mobile-menu"
    class="hidden border-t border-line/70 bg-paper px-5 pb-5 pt-2 md:hidden"
  >
    {
      NAV.map((item) => (
        <a
          href={item.href}
          class="block rounded-lg px-3 py-3 text-[15px] text-ink-dim hover:bg-card hover:text-ink focus-visible:outline-2 focus-visible:outline-brand"
        >
          {item.label}
        </a>
      ))
    }
  </div>
  <span
    id="scroll-progress"
    class="absolute bottom-0 left-0 h-0.5 bg-brand"
    style="width: 0%"
    aria-hidden="true"></span>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? '메뉴 닫기' : '메뉴 열기');
  });

  // 스크롤 시 헤더 축소 + 그림자
  const header = document.getElementById('site-header');
  const nav = header?.querySelector('nav');
  const bar = document.getElementById('scroll-progress');
  const onScroll = () => {
    const scrolled = window.scrollY > 24;
    if (bar) {
      const max = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.width = max > 0 ? `${(window.scrollY / max) * 100}%` : '0%';
    }
    nav?.classList.toggle('h-16', !scrolled);
    nav?.classList.toggle('h-14', scrolled);
    header?.classList.toggle('shadow-[0_8px_24px_-16px_color-mix(in_srgb,var(--color-ink)_35%,transparent)]', scrolled);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
