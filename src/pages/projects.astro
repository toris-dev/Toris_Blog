---
import Base from '../layouts/Base.astro';
import CardFX from '../components/CardFX.astro';
import ProjectCover from '../components/ProjectCover.astro';
import { covers } from '../data/covers';
import { SITE_URL, absoluteUrl } from '../lib/site';
// 기존 Next 프로젝트 데이터 재사용 (원본 단일 출처)
import { projects } from '../data/projects';

const live = projects.filter((p) => p.status === '운영 중');
const building = projects.filter((p) => p.status === '개발 중');
const shipped = projects.filter((p) => p.status === '출시');

// 에디토리얼 하이어라키 — 실제 커버가 있는 운영 제품을 대표작으로
const featured = live.find((p) => covers[p.slug]) ?? live[0];
const liveRest = live.filter((p) => p !== featured);

// 서비스 링크(웹사이트·스토어·릴리스 다운로드)만 클릭 허용.
// GitHub 리포/프로필 루트로만 가는 항목은 카드 링크를 제거한다.
const isServiceLink = (url: string) =>
  !url.startsWith('https://github.com/') || /\/releases\/?$/.test(url);

// 제품 구조화 데이터 — 운영 중 제품을 SoftwareApplication ItemList로 노출
const osOf = (platform: string) => {
  const s = platform.toLowerCase();
  if (/desktop|macos|windows|linux/.test(s)) return 'macOS, Windows, Linux';
  if (/mobile|ios|android/.test(s)) return 'iOS, Android';
  if (/npm|library|node/.test(s)) return 'Node.js';
  return 'Web';
};
const productsJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: '토리스가 운영 중인 제품',
  itemListElement: live.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'SoftwareApplication',
      name: p.name,
      description: p.tagline,
      applicationCategory: p.category,
      operatingSystem: osOf(p.platform),
      ...(isServiceLink(p.github) ? { url: p.github } : {}),
      author: { '@type': 'Organization', name: '토리스', url: SITE_URL },
      brand: { '@type': 'Brand', name: '토리스 (Toris)' },
      image: absoluteUrl('/og-default.png'),
      // 전 제품 무료 공개 — Software App 리치 결과 요건(offers)
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'KRW',
        availability: 'https://schema.org/InStock',
        ...(isServiceLink(p.github) ? { url: p.github } : {})
      }
    }
  }))
});
---

<Base
  title="프로젝트 | 토리스"
  description="토리스가 직접 기획·개발·운영하는 제품들 — 웹, 모바일, 자동화까지 만든 것들을 모았습니다."
  path="/projects"
  pageType="CollectionPage"
  breadcrumbs={[{ name: '홈', url: '/' }, { name: '프로젝트' }]}
>
  <script type="application/ld+json" set:html={productsJsonLd} />
  <!-- ============================== Hero ============================== -->
  <section class="mx-auto max-w-6xl px-5 pb-6 pt-20 sm:pt-28">
    <div class="reveal flex items-center gap-4">
      <span class="rule-accent w-16" aria-hidden="true"></span>
      <p class="text-xs font-semibold tracking-[0.35em] text-brand">PRODUCTS</p>
    </div>
    <h1
      class="reveal font-display mt-6 text-4xl text-ink sm:text-5xl"
      style="transition-delay: 60ms"
    >
      만든 것들
    </h1>
    <p
      class="reveal mt-5 max-w-xl break-keep text-lg leading-relaxed text-ink-dim"
      style="transition-delay: 120ms"
    >
      직접 기획하고, 개발하고, 운영하는 제품들입니다. 작게 시작해서 꾸준히
      고치며 키워갑니다.
    </p>
  </section>

  <!-- ==================== 운영 중 — 대표작 + 미디엄 ==================== -->
  <section class="mx-auto max-w-6xl px-5 py-14" aria-label="운영 중 프로젝트">
    <h2 class="reveal font-display flex items-center gap-3 text-2xl text-ink">
      <span class="size-1.5 rounded-full bg-live" aria-hidden="true"></span>
      운영 중
      <span class="text-sm font-normal tracking-wider text-muted">{live.length}</span>
    </h2>

    {featured && (() => { const linked = isServiceLink(featured.github); const Tag = linked ? 'a' : 'div'; return (
      <Tag
        href={linked ? featured.github : undefined}
        target={linked ? '_blank' : undefined}
        rel={linked ? 'noopener noreferrer' : undefined}
        class="reveal group relative mt-8 grid overflow-hidden rounded-2xl border border-line bg-card transition-[border-color,box-shadow] duration-300 hover:border-brand/70 hover:shadow-(--shadow-lift) focus-visible:outline-2 focus-visible:outline-brand lg:grid-cols-[7fr_5fr]"
      >
        <ProjectCover
          project={featured}
          class="aspect-[16/9] w-full lg:aspect-auto lg:h-full"
          sizes="(min-width: 1024px) 58vw, 100vw"
          loading="eager"
        />
        <div class="flex flex-col p-7 sm:p-9">
          <p class="font-mono text-[10px] tracking-[0.24em] text-brand uppercase">FEATURED · {featured.category}</p>
          <h3 class="font-display mt-4 text-3xl text-ink sm:text-4xl">{featured.name}</h3>
          <p class="mt-3 break-keep text-[15px] font-medium leading-relaxed text-ink-dim">{featured.tagline}</p>
          <p class="mt-4 break-keep text-sm leading-relaxed text-muted">{featured.description}</p>
          <p class="mt-5 text-xs tracking-wide text-muted">{featured.tech.slice(0, 5).join(' · ')}</p>
          <div class="mt-auto flex items-center justify-between gap-3 pt-7">
            <span class="flex items-center gap-2 text-[11px] tracking-wider text-live">
              <span class="size-1.5 rounded-full bg-live" aria-hidden="true"></span>
              {featured.status} · {featured.platform}
            </span>
            {linked && (
              <span class="flex items-center gap-1.5 text-[13px] font-medium text-muted transition-colors duration-300 group-hover:text-brand">
                서비스 열기
                <svg viewBox="0 0 24 24" class="size-3.5 transition-transform duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M7 17 17 7M9 7h8v8" />
                </svg>
              </span>
            )}
          </div>
        </div>
        <span class="absolute -bottom-px left-0 h-0.5 w-0 bg-brand transition-all duration-500 group-hover:w-full" aria-hidden="true" />
      </Tag>
    ); })()}

    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      {liveRest.map((p, i) => { const linked = isServiceLink(p.github); const Tag = linked ? 'a' : 'div'; return (
        <Tag
          href={linked ? p.github : undefined}
          target={linked ? '_blank' : undefined}
          rel={linked ? 'noopener noreferrer' : undefined}
          class="card-3d reveal group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-card transition-[border-color,box-shadow] duration-300 hover:border-brand/70 hover:shadow-(--shadow-lift) focus-visible:outline-2 focus-visible:outline-brand"
          style={`transition-delay: ${i * 60}ms`}
        >
          <span class="card-glare" aria-hidden="true" />
          <ProjectCover project={p} class="aspect-[16/9] w-full" sizes="(min-width: 640px) 50vw, 100vw" />
          <div class="flex grow flex-col p-6">
            <p class="text-[11px] font-medium uppercase tracking-[0.3em] text-muted">{p.category}</p>
            <h3 class="font-display mt-2 text-2xl text-ink">{p.name}</h3>
            <p class="mt-2 break-keep text-sm leading-relaxed text-ink-dim">{p.tagline}</p>
            <span class="mt-auto flex items-center justify-between gap-3 pt-6">
              <span class="flex items-center gap-2 text-[11px] tracking-wider text-live">
                <span class="size-1.5 rounded-full bg-live" aria-hidden="true" />
                {p.status} · {p.platform}
              </span>
              {linked && (
                <span class="flex items-center gap-1.5 text-[13px] font-medium text-muted transition-colors duration-300 group-hover:text-brand">
                  서비스 열기
                  <svg viewBox="0 0 24 24" class="size-3.5 transition-transform duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M7 17 17 7M9 7h8v8" />
                  </svg>
                </span>
              )}
            </span>
            <span class="absolute -bottom-px left-0 h-px w-0 bg-brand transition-all duration-500 group-hover:w-full" aria-hidden="true" />
          </div>
        </Tag>
      ); })}
    </div>
  </section>

  <!-- ==================== 개발 중 — 미디엄 커버 카드 ==================== -->
  {building.length > 0 && (
    <section class="mx-auto max-w-6xl px-5 py-14" aria-label="개발 중 프로젝트">
      <h2 class="reveal font-display flex items-center gap-3 text-2xl text-ink">
        <span class="size-1.5 rounded-full bg-brand" aria-hidden="true"></span>
        개발 중
        <span class="text-sm font-normal tracking-wider text-muted">{building.length}</span>
      </h2>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {building.map((p, i) => { const linked = isServiceLink(p.github); const Tag = linked ? 'a' : 'div'; return (
          <Tag
            href={linked ? p.github : undefined}
            target={linked ? '_blank' : undefined}
            rel={linked ? 'noopener noreferrer' : undefined}
            class="card-3d reveal group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-card transition-[border-color] duration-300 hover:border-brand/70 focus-visible:outline-2 focus-visible:outline-brand"
            style={`transition-delay: ${i * 60}ms`}
          >
            <span class="card-glare" aria-hidden="true" />
            <ProjectCover project={p} class="aspect-[16/10] w-full" sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw" />
            <div class="flex grow flex-col p-6">
              <p class="text-[11px] font-medium uppercase tracking-[0.3em] text-muted">{p.category}</p>
              <h3 class="font-display mt-2 text-xl text-ink">{p.name}</h3>
              <p class="mt-2 break-keep text-sm leading-relaxed text-ink-dim">{p.tagline}</p>
              <span class="mt-auto flex items-center justify-between gap-3 pt-6">
                <span class="flex items-center gap-2 text-[11px] tracking-wider text-brand">
                  <span class="size-1.5 rounded-full bg-brand" aria-hidden="true" />
                  {p.status}
                </span>
                {linked && (
                  <span class="flex items-center gap-1.5 text-[13px] font-medium text-muted transition-colors duration-300 group-hover:text-brand">
                    서비스 열기
                    <svg viewBox="0 0 24 24" class="size-3.5 transition-transform duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M7 17 17 7M9 7h8v8" />
                    </svg>
                  </span>
                )}
              </span>
              <span class="absolute -bottom-px left-0 h-px w-0 bg-brand transition-all duration-500 group-hover:w-full" aria-hidden="true" />
            </div>
          </Tag>
        ); })}
      </div>
    </section>
  )}

  <!-- ===================== 출시 — 컴팩트 카드 ===================== -->
  {shipped.length > 0 && (
    <section class="mx-auto max-w-6xl px-5 py-14" aria-label="출시 프로젝트">
      <h2 class="reveal font-display flex items-center gap-3 text-2xl text-ink">
        <span class="size-1.5 rounded-full bg-sand" aria-hidden="true"></span>
        출시
        <span class="text-sm font-normal tracking-wider text-muted">{shipped.length}</span>
      </h2>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {shipped.map((p, i) => { const linked = isServiceLink(p.github); const Tag = linked ? 'a' : 'div'; return (
          <Tag
            href={linked ? p.github : undefined}
            target={linked ? '_blank' : undefined}
            rel={linked ? 'noopener noreferrer' : undefined}
            class="reveal group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-card p-6 transition-[border-color] duration-300 hover:border-brand/60 focus-visible:outline-2 focus-visible:outline-brand"
            style={`transition-delay: ${i * 60}ms`}
          >
            <p class="text-[11px] font-medium uppercase tracking-[0.3em] text-muted">{p.category}</p>
            <h3 class="font-display mt-2 text-xl text-ink">{p.name}</h3>
            <p class="mt-2 break-keep text-sm leading-relaxed text-ink-dim">{p.tagline}</p>
            <span class="mt-auto flex items-center justify-between gap-3 pt-6">
              <span class="flex items-center gap-2 text-[11px] tracking-wider text-muted">
                <span class="size-1.5 rounded-full bg-sand" aria-hidden="true" />
                {p.status} · {p.year}
              </span>
              {linked && (
                <span class="flex items-center gap-1.5 text-[13px] font-medium text-muted transition-colors duration-300 group-hover:text-brand">
                  서비스 열기
                  <svg viewBox="0 0 24 24" class="size-3.5 transition-transform duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M7 17 17 7M9 7h8v8" />
                  </svg>
                </span>
              )}
            </span>
            <span class="absolute -bottom-px left-0 h-px w-0 bg-brand transition-all duration-500 group-hover:w-full" aria-hidden="true" />
          </Tag>
        ); })}
      </div>
    </section>
  )}

  <!-- =============================== CTA =============================== -->
  <section class="mx-auto max-w-6xl px-5 py-20">
    <div class="reveal relative overflow-hidden rounded-2xl border border-line bg-card px-8 py-14 text-center">
      <span class="rule-accent absolute inset-x-0 top-0" aria-hidden="true"></span>
      <h2 class="font-display text-2xl text-ink sm:text-3xl">
        이런 제품, 함께 만들어볼까요?
      </h2>
      <p class="mx-auto mt-3 max-w-xl break-keep text-ink-dim">
        아이디어 단계여도 좋습니다. 만들고 싶은 것을 들려주세요.
      </p>
      <a
        href="/contact"
        class="mt-8 inline-flex h-12 items-center gap-2 border border-brand bg-brand rounded-lg px-8 text-[15px] font-semibold text-paper transition-all duration-300 hover:-translate-y-0.5 hover:bg-brand-bright hover:shadow-[0_8px_32px_-8px_color-mix(in_srgb,var(--color-brand)_45%,transparent)] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-brand active:translate-y-0"
      >
        프로젝트 문의하기
        <svg
          viewBox="0 0 24 24"
          class="size-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M5 12h14m-6-6 6 6-6 6"></path>
        </svg>
      </a>
    </div>
  </section>

  <CardFX />
</Base>
