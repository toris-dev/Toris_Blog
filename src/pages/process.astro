---
import Base from '../layouts/Base.astro';
import CardFX from '../components/CardFX.astro';
import { COMPANY } from '../lib/site';

const steps = [
  {
    n: '01',
    title: '문의 · 상담',
    body: '만들고 싶은 것과 배경, 제약을 먼저 듣습니다. 문의 후 24시간 안에 회신드리며, 필요하시면 상담 전에 NDA(비밀유지계약)를 체결합니다.',
    outputs: ['24시간 내 1차 회신', 'NDA 체결(선택)', '요구사항 초안 정리']
  },
  {
    n: '02',
    title: '스코핑',
    body: '무엇을, 언제까지, 얼마에 만들지 문서로 확정합니다. 범위를 밀스톤 단위로 쪼개 각 단계의 완료 기준을 함께 정의합니다.',
    outputs: ['범위·일정·비용 확정 문서', '밀스톤 정의서', '계약서']
  },
  {
    n: '03',
    title: '설계 · 프로토타입',
    body: '문서보다 만질 수 있는 초안이 방향을 빠르게 검증합니다. 핵심 화면과 흐름을 프로토타입으로 만들어 본격 개발 전에 방향을 확정합니다.',
    outputs: ['화면 설계·와이어프레임', '동작하는 프로토타입', '기술 스택 결정 문서']
  },
  {
    n: '04',
    title: '개발 · 검증',
    body: '주 단위로 동작하는 데모를 공유합니다. 진행 상황이 항상 보이도록 소통 채널을 열어두고, 피드백은 다음 주 데모에 반영합니다.',
    outputs: ['주간 데모·진행 리포트', '테스트 가능한 스테이징 환경', '변경 이력 문서']
  },
  {
    n: '05',
    title: '출시 · 운영',
    body: '배포로 끝나지 않습니다. 모니터링과 지표를 함께 보며 개선점을 찾고, 출시 이후의 안정화와 운영까지 책임집니다.',
    outputs: ['프로덕션 배포', '모니터링·알림 구성', '지표 기반 개선 제안']
  }
];

const principles = [
  {
    title: '주 단위 공유',
    body: '"잘 되고 있어요"라는 말 대신 동작하는 데모를 보여드립니다. 매주 진행 상황을 눈으로 확인하실 수 있습니다.',
    icon: 'M8 7V3m8 4V3M4 11h16M5 5h14a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Z'
  },
  {
    title: '문서로 남기는 결정',
    body: '범위, 일정, 기술 선택 — 중요한 결정은 모두 문서로 남깁니다. 나중에 "왜 이렇게 했지?"가 없도록요.',
    icon: 'M4 5a2 2 0 0 1 2-2h9l5 5v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5Zm11-2v5h5M8 13h8M8 17h5'
  },
  {
    title: '출시 후에도 책임',
    body: '납품하고 사라지지 않습니다. 출시 이후의 버그, 안정화, 개선까지 만든 사람이 끝까지 함께합니다.',
    icon: 'M12 3l7 4v5c0 4.5-3 8.2-7 9-4-.8-7-4.5-7-9V7l7-4Zm-3 9 2.2 2.2L15 10.5'
  }
];

const faqs = [
  {
    q: '토리스(Toris)는 어떤 회사인가요?',
    a: '토리스는 웹·모바일·AI 자동화 제품을 기획부터 출시, 운영까지 책임지는 대한민국 서울의 소프트웨어 개발 스튜디오입니다. 정식 등록된 사업자(사업자등록번호 424-04-03521)로 계약과 세금계산서 발행이 가능하며, 밈캐치·TraceDesk 등 직접 만든 제품을 운영하고 있습니다.'
  },
  {
    q: '동명의 다른 토리스와 같은 곳인가요?',
    a: '아니요. 소프트웨어 스튜디오 토리스(toris.kr, Toris)는 같은 이름을 쓰는 음악 그룹이나 다른 업종의 법인과 무관한 별개 회사입니다.'
  },
  {
    q: '기간은 보통 얼마나 걸리나요?',
    a: '범위에 따라 다르지만, MVP는 4~8주, 정식 제품은 2~4개월을 기준으로 잡습니다. 스코핑 단계에서 밀스톤별 일정을 문서로 확정해 드리므로, 시작 전에 전체 그림을 아실 수 있습니다.'
  },
  {
    q: '비용은 어떻게 산정하나요?',
    a: '확정된 범위 기준의 프로젝트 단위 견적을 기본으로 합니다. 밀스톤별로 금액을 나누어 각 단계 완료 시 정산하며, 범위가 바뀌면 변경 견적을 문서로 먼저 합의한 뒤 진행합니다.'
  },
  {
    q: '출시 후 유지보수 계약도 가능한가요?',
    a: '네. 월 단위 유지보수 계약으로 모니터링, 버그 대응, 소규모 개선을 이어갈 수 있습니다. 유지보수 없이 인수인계만 원하시는 경우에도 운영 문서와 코드 설명을 충분히 남겨드립니다.'
  },
  {
    q: '원격으로만 진행하나요?',
    a: '네, 기본은 원격입니다. 슬랙·노션·주간 화상 데모로 소통하며, 필요한 경우 서울·경기 지역은 대면 미팅도 가능합니다. 모든 결정 사항은 문서로 남겨 시차나 채널에 관계없이 같은 정보를 보게 합니다.'
  },
  {
    q: '기존 서비스의 유지보수·개선만 맡길 수도 있나요?',
    a: '가능합니다. 코드 인수 점검(1~2주)으로 현재 상태를 문서화한 뒤, 월 단위 유지보수 또는 개선 스프린트로 진행합니다. 다른 개발자가 만든 레거시도 점진적 마이그레이션 원칙으로 안전하게 다룹니다.'
  },
  {
    q: '어떤 기술을 쓰나요?',
    a: '웹은 Next.js·Astro, 모바일은 Flutter·React Native, 자동화는 Node.js 기반 파이프라인과 LLM 워크플로를 주로 씁니다. 다만 기술은 수단입니다 — 프로젝트의 목표와 운영 환경에 맞는 스택을 스코핑 단계에서 함께 결정합니다.'
  }
];

// FAQ 구조화 데이터 — 화면의 faqs 배열과 단일 출처
const faqJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://toris.kr/process#faq',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a }
  }))
});
---

<Base
  title="진행 방식 | 토리스"
  description={`${COMPANY.nameKo}(${COMPANY.nameEn})의 프로젝트 진행 방식 — 문의부터 출시·운영까지 투명한 5단계로 진행합니다.`}
  path="/process"
  breadcrumbs={[{ name: '홈', url: '/' }, { name: '진행 방식' }]}
>
  <script type="application/ld+json" set:html={faqJsonLd} />
  <!-- ============================== Hero ============================== -->
  <section class="mx-auto max-w-6xl px-5 pb-20 pt-24 sm:pt-32">
    <div class="reveal max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-mint">Process</p>
      <h1 class="mt-3 text-4xl font-extrabold leading-[1.12] tracking-tight text-ink sm:text-5xl">
        이렇게 진행합니다
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-muted">
        문의부터 출시, 운영까지 다섯 단계로 진행합니다. 각 단계의 산출물과
        완료 기준을 미리 정해두기 때문에, 지금 어디까지 왔고 다음에 무엇이
        오는지 항상 투명하게 아실 수 있습니다.
      </p>
    </div>
  </section>

  <!-- ============================ Timeline ============================ -->
  <section class="border-t border-line bg-card">
    <div class="mx-auto max-w-6xl px-5 py-24">
      <ol class="relative max-w-3xl">
        <!-- 세로 라인 -->
        <span
          class="absolute bottom-6 left-[23px] top-3 w-px bg-line"
          aria-hidden="true"></span>
        {
          steps.map((s, i) => (
            <li
              class="reveal relative pb-14 pl-20 last:pb-0"
              style={`transition-delay: ${i * 80}ms`}
            >
              <!-- 노드 -->
              <span
                class="absolute left-0 top-0 flex size-12 items-center justify-center rounded-full border-2 border-mint-deep/60 bg-paper"
                aria-hidden="true"
              >
                <span class="size-2.5 rounded-full bg-mint" />
              </span>
              <p class="text-sm font-extrabold tabular-nums text-mint">{s.n}</p>
              <h2 class="mt-1 text-2xl font-display text-ink">{s.title}</h2>
              <p class="mt-3 max-w-xl text-[15px] leading-relaxed text-muted">{s.body}</p>
              <ul class="mt-5 space-y-2">
                {s.outputs.map((o) => (
                  <li class="flex items-center gap-2.5 text-sm font-medium text-ink-dim">
                    <svg
                      viewBox="0 0 24 24"
                      class="size-4 shrink-0 text-mint"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.4"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M5 13l4 4L19 7" />
                    </svg>
                    {o}
                  </li>
                ))}
              </ul>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- =========================== Principles =========================== -->
  <section class="border-t border-line bg-card">
    <div class="mx-auto max-w-6xl px-5 py-24">
      <div class="reveal max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-mint">Principles</p>
        <h2 class="mt-3 text-3xl font-display text-ink sm:text-4xl">
          함께 일하는 원칙
        </h2>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {
          principles.map((p, i) => (
            <article
              class="reveal card-3d relative overflow-hidden rounded-2xl border border-line group bg-card p-7 transition-[border-color] duration-300 hover:border-mint-deep"
              style={`transition-delay: ${i * 80}ms`}
            >
              <span class="flex size-12 items-center justify-center bg-mint/10 text-mint transition-colors group-hover:bg-mint group-hover:text-paper">
                <svg viewBox="0 0 24 24" class="size-6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={p.icon} />
                </svg>
              </span>
              <h3 class="mt-5 text-lg font-bold text-ink">{p.title}</h3>
              <p class="mt-2.5 text-[15px] leading-relaxed text-muted">{p.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- =============================== FAQ =============================== -->
  <section class="border-t border-line bg-card">
    <div class="mx-auto max-w-6xl px-5 py-24">
      <div class="reveal max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-mint">FAQ</p>
        <h2 class="mt-3 text-3xl font-display text-ink sm:text-4xl">
          자주 묻는 질문
        </h2>
      </div>
      <div class="mt-12 max-w-3xl space-y-4">
        {
          faqs.map((f, i) => (
            <details
              class="faq-item reveal group rounded-2xl border border-line bg-paper transition-colors open:border-mint-deep"
              style={`transition-delay: ${i * 60}ms`}
            >
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 rounded-2xl px-7 py-5 text-[15px] font-bold text-ink focus-visible:outline-2 focus-visible:outline-mint">
                {f.q}
                <svg
                  viewBox="0 0 24 24"
                  class="size-5 shrink-0 text-mint transition-transform group-open:rotate-45"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  aria-hidden="true"
                >
                  <path d="M12 5v14M5 12h14" />
                </svg>
              </summary>
              <p class="px-7 pb-6 text-[15px] leading-relaxed text-muted">{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- =============================== CTA =============================== -->
  <section class="mx-auto max-w-6xl px-5 py-24">
    <div class="reveal rounded-3xl bg-paper-2 px-8 py-14 text-center sm:px-16">
      <h2 class="text-3xl font-display text-ink">
        첫 단계는 문의입니다
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-ink-dim">
        무엇을, 왜 만들고 싶은지 들려주세요 — 24시간 안에 답장드립니다.
      </p>
      <a
        href="/contact"
        class="mt-8 inline-flex h-12 items-center gap-2 rounded-full bg-mint px-8 text-[15px] font-bold text-paper transition-all hover:-translate-y-0.5 hover:bg-mint-bright focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white active:translate-y-0"
      >
        프로젝트 문의하기
      </a>
    </div>
  </section>
  <CardFX />
</Base>

<style>
  /* Safari 등에서 summary 기본 마커 제거 */
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
</style>
