{
  "name": "@fieldstep/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/worker.ts",
  "scripts": {
    "dev": "wrangler dev --port 8788",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute fieldstep --local --file=./d1/0000_init.sql",
    "db:migrate:remote": "wrangler d1 execute fieldstep --remote --file=./d1/0000_init.sql"
  },
  "dependencies": {
    "@fieldstep/shared": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260719.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.2",
    "better-sqlite3": "^11.7.0",
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "wrangler": "^4.26.0"
  }
}
